[466.683473, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[466.684103, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java"]
[466.684473, "o", "\r\n\u001b[?2004l\r"]
[466.686835, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor.close();\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[466.68731, "o", "\u001b[?2004h"]
[466.687508, "o", "root@c183eb9ac99e:/workspace/textd# "]
