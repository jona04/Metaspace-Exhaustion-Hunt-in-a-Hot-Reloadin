[769.264294, "o", "\u001b[?2004l\r"]
[769.264452, "o", "\u001b[?2004h"]
[769.26627, "o", "> "]
[769.267642, "o", "    private final AtomicInteger pins = new AtomicInteger(1);"]
[769.268363, "o", "\r\n"]
[769.269086, "o", "\u001b[?2004l\r\u001b[?2004h"]
[769.270817, "o", "> "]
[769.271697, "o", "    private final AtomicBoolean cooled = new AtomicBoolean(false);"]
[769.27242, "o", "\r\n"]
[769.273029, "o", "\u001b[?2004l\r\u001b[?2004h"]
[769.275912, "o", ">     private final AtomicBoolean closed = new AtomicBoolean(false);"]
[769.276815, "o", "\r\n"]
[769.277056, "o", "\u001b[?2004l\r\u001b[?2004h"]
[769.277697, "o", "> "]
[769.278688, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[769.27978, "o", "> "]
[769.28002, "o", "    TimelineFrame(LoadedGeneration loadedGeneration) {"]
[769.284148, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.28451, "o", "        this.loadedGeneration = loadedGeneration;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.284756, "o", "    TimelineFrame pin() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.284974, "o", "        while (true) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.285779, "o", "            int current = pins.get();\r\n\u001b[?2004l\r\u001b[?2004h"]
[769.291991, "o", "> "]
[769.292405, "o", "            if (current <= 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.292956, "o", "                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.293227, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.29395, "o", "            if (pins.compareAndSet(current, current + 1)) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.294466, "o", "                return this;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[769.299113, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[769.299369, "o", "\u001b[?2004h>     long revision() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.299871, "o", "        return loadedGeneration.generation();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.300235, "o", "    PluginModule module() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.300693, "o", "        return loadedGeneration.module();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.300906, "o", "    void cool() {\r\n\u001b[?2004l\r\u001b[?2004h>         if (cooled.compareAndSet(false, true)) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.309184, "o", "            unpin();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.309832, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     void unpin() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.310221, "o", "        int remaining = pins.decrementAndGet();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.315196, "o", "        if (remaining == 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.315401, "o", "            closeLoadedGeneration();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.315987, "o", "        } else if (remaining < 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.316496, "o", "            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.316678, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     boolean isDrained() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.316944, "o", "        return closed.get();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.321068, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[769.321379, "o", "> "]
[769.321563, "o", "    private void closeLoadedGeneration() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.32178, "o", "        if (closed.compareAndSet(false, true)) {\r\n\u001b[?2004l\r\u001b[?2004h>             try {\r\n\u001b[?2004l\r"]
[769.322137, "o", "\u001b[?2004h> "]
[769.328274, "o", "                loadedGeneration.close();\r\n\u001b[?2004l\r"]
[769.328761, "o", "\u001b[?2004h> "]
[769.329868, "o", "            } catch (Exception exception) {\r\n\u001b[?2004l\r\u001b[?2004h>                 throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.329951, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[769.343377, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[774.703264, "i", "cat > src/main/java/io/harbor/textd/core/ThreadCache.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class ThreadCache implements AutoCloseable {\n    private WorkerHandle cursor;\n\n    WorkerHandle cursorFor(TimelineLedger ledger) {\n        if (cursor != null) {\n            cursor.close();\n        }\n        cursor = new WorkerHandle(ledger.current());\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
