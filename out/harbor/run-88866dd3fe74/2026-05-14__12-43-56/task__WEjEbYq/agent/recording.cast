[470.139067, "i", "cat > src/main/java/io/harbor/textd/core/ThreadBridge.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class ThreadBridge {\n    private static final ThreadLocal<ThreadCache> ROUTES = new ThreadLocal<>();\n\n    private ThreadBridge() {\n    }\n\n    static WorkerHandle current(TimelineLedger ledger) {\n        ThreadCache cache = ROUTES.get();\n        if (cache == null) {\n            cache = new ThreadCache();\n            ROUTES.set(cache);\n        }\n        return cache.cursorFor(ledger);\n    }\n\n    static void clear() {\n        ThreadCache cache = ROUTES.get();\n        if (cache != null) {\n            cache.close();\n            ROUTES.remove();\n        }\n    }\n}\nEOF\n"]
