[223.763889, "i", "cat bin/replay-check\n"]
[223.764295, "o", "cat bin/replay-check\r\n\u001b[?2004l\r"]
[223.766029, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\nif [[ \"${TEXTD_SKIP_BUILD:-0}\" != \"1\" ]]; then\r\n  \"$ROOT_DIR/bin/build\"\r\nfi\r\n\r\nREPLAY_TMP=$(mktemp)\r\ntrap 'rm -f \"$REPLAY_TMP\"' EXIT\r\n\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.SessionReplayRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" 4 > \"$REPLAY_TMP\"\r\n\r\npython3 - \"$REPLAY_TMP\" <<'PYEOF'\r\nimport json, sys\r\n\r\nwith open(sys.argv[1]) as f:\r\n    data = json.load(f)\r\n\r\nfirst  = data['first']\r\nsecond = data['second']\r\n\r\nd1 = first['unloaded_after_close']  - first['unloaded_before_close']\r\nd2 = second['unloaded_after_close'] - second['unloaded_before_close']\r\n\r\nif d1 > 0 and d2 > 0:\r\n    print(f\"replay-ok unloaded-first={d1} unloaded-second={d2}\")\r\nelse:\r\n    print(f\"replay-fail unloaded-first={d1} unloaded-second={d2}\", file=sys.stderr)\r\n    sys.exit(1)\r\nPYEOF\r\n"]
[223.766472, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[228.937534, "i", "cat src/main/java/io/harbor/textd/cli/SessionReplayRunner.java\n"]
[228.938067, "o", "cat src/main/java/io/harbor/textd/cli/SessionReplayRunner.java\r\n\u001b[?2004l\r"]
[228.939514, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.lang.management.ClassLoadingMXBean;\r\nimport java.lang.management.ManagementFactory;\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\nimport java.util.stream.Collectors;\r\n\r\npublic final class SessionReplayRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n    private static final ClassLoadingMXBean CLASS_LOADING = ManagementFactory.getClassLoadingMXBean();\r\n\r\n    private SessionReplayRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int revision = args.length > 1 ? Integer.parseInt(args[1]) : 24;\r\n\r\n        Session first = runSession(pluginJar, revision);\r\n        Session second = runSession(pluginJar, revision);\r\n\r\n        System.out.println(\"{\");\r\n        System.out.println(\"  \\\"first\\\": \" + first.toJson() + \",\");\r\n        System.out.println(\"  \\\"second\\\": \" + second.toJson());\r\n        System.out.println(\"}\");\r\n    }\r\n\r\n    private static Session runSession(Path pluginJar, int revision) throws Exception {\r\n        long loadedBefore = CLASS_LOADING.getLoadedClassCount();\r\n        long unloadedBefore = CLASS_LOADING.getUnloadedClassCount();\r\n\r\n        TextDaemon daemon = new TextDaemon(pluginJar, 4);\r\n        try {\r\n            daemon.reload(1);\r\n            List<ProcessingResult> firstResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n            assertOutputs(1, firstResults);\r\n\r\n            List<String> workersStart = workerThreads(firstResults);\r\n            List<ProcessingResult> finalResults = firstResults;\r\n            for (int current = 2; current <= revision; current++) {\r\n                daemon.reload(current);\r\n                finalResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n                assertOutputs(current, finalResults);\r\n            }\r\n\r\n            List<String> workersEnd = workerThreads(finalResults);\r\n            boolean sameWorkers = workersStart.equals(workersEnd);\r\n            boolean beforeClose = daemon.isBalanced();\r\n            String first = firstResults.get(0).output();\r\n            String last = finalResults.get(0).output();\r\n\r\n            daemon.close();\r\n            drainGc();\r\n\r\n            return new Session(\r\n                first,\r\n                last,\r\n                workersStart,\r\n                workersEnd,\r\n                sameWorkers,\r\n                beforeClose,\r\n                daemon.isBalanced(),\r\n                loadedBefore,\r\n                CLASS_LOADING.getLoadedClassCount(),\r\n                unloadedBefore,\r\n                CLASS_LOADING.getUnloadedClassCount()\r\n            );\r\n        } catch (Exception exception) {\r\n            try {\r\n                daemon.close();\r\n            } catch (Exception closeException) {\r\n                exception.addSuppressed(closeException);\r\n            }\r\n            throw exception;\r\n        }\r\n    }\r\n\r\n    private static List<String> workerThreads(List<ProcessingResult> results) {\r\n        return results.stream()\r\n            .map(ProcessingResult::workerThread)\r\n            .sorted()\r\n            .collect(Collectors.toList());\r\n    }\r\n\r\n    private static void drainGc() throws InterruptedException {\r\n        for (int i = 0; i < 3; i++) {\r\n            System.gc();\r\n            Thread.sleep(50);\r\n        }\r\n    }\r\n\r\n    private static void assertOutputs(long revision, List<ProcessingResult> results) {\r\n        String expected = OutputFormat.expectedFor(revision, SAMPLE);\r\n        for (ProcessingResult result : results) {\r\n            if (!expected.equals(result.output())) {\r\n                throw new IllegalStateException(\"Unexpected output at revision \" + revision + \": \" + result.output());\r\n            }\r\n        }\r\n    }\r\n\r\n    private static String toJsonArray(List<String> values) {\r\n        return values.stream()\r\n            .map(value -> \"\\\"\" + value + \"\\\"\")\r\n            .collect(Collectors."]
[228.939595, "o", "joining(\", \", \"[\", \"]\"));\r\n    }\r\n\r\n    private static final class Session {\r\n        private final String first;\r\n        private final String last;\r\n        private final List<String> start;\r\n        private final List<String> end;\r\n        private final boolean sameWorkers;\r\n        private final boolean beforeClose;\r\n        private final boolean afterClose;\r\n        private final long loadedBeforeClose;\r\n        private final long loadedAfterClose;\r\n        private final long unloadedBeforeClose;\r\n        private final long unloadedAfterClose;\r\n\r\n        private Session(\r\n            String first,\r\n            String last,\r\n            List<String> start,\r\n            List<String> end,\r\n            boolean sameWorkers,\r\n            boolean beforeClose,\r\n            boolean afterClose,\r\n            long loadedBeforeClose,\r\n            long loadedAfterClose,\r\n            long unloadedBeforeClose,\r\n            long unloadedAfterClose\r\n        ) {\r\n            this.first = first;\r\n            this.last = last;\r\n            this.start = start;\r\n            this.end = end;\r\n            this.sameWorkers = sameWorkers;\r\n            this.beforeClose = beforeClose;\r\n            this.afterClose = afterClose;\r\n            this.loadedBeforeClose = loadedBeforeClose;\r\n            this.loadedAfterClose = loadedAfterClose;\r\n            this.unloadedBeforeClose = unloadedBeforeClose;\r\n            this.unloadedAfterClose = unloadedAfterClose;\r\n        }\r\n\r\n        private String toJson() {\r\n            return \"{\"\r\n                + \"\\\"first\\\":\\\"\" + first + \"\\\",\"\r\n                + \"\\\"last\\\":\\\"\" + last + \"\\\",\"\r\n                + \"\\\"start\\\":\" + toJsonArray(start) + \",\"\r\n                + \"\\\"end\\\":\" + toJsonArray(end) + \",\"\r\n                + \"\\\"same_workers\\\":\" + sameWorkers + \",\"\r\n                + \"\\\"before_close\\\":\" + beforeClose + \",\"\r\n                + \"\\\"after_close\\\":\" + afterClose + \",\"\r\n                + \"\\\"loaded_before_close\\\":\" + loadedBeforeClose + \",\"\r\n                + \"\\\"loaded_after_close\\\":\" + loadedAfterClose + \",\"\r\n                + \"\\\"unloaded_before_close\\\":\" + unloadedBeforeClose + \",\"\r\n                + \"\\\"unloaded_after_close\\\":\" + unloadedAfterClose\r\n                + \"}\";\r\n        }\r\n    }\r\n}\r\n"]
[228.939943, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[233.402359, "i", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\n"]
[233.402915, "o", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\r\n\u001b[?2004l\r"]
[233.404144, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\nimport java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final TimelineLedger revisions;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.revisions = new TimelineLedger(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        revisions.install(generation);\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public boolean isBalanced() {\r\n        return revisions.isBalanced();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        WorkerHandle binding = ThreadBridge.current(revisions);\r\n        return binding.process(record);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        revisions.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[233.404386, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[236.243581, "i", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\n"]
[236.244228, "o", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\r\n\u001b[?2004l\r"]
[236.245597, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadBridge {\r\n    private static final ThreadLocal<ThreadCache> ROUTES = ThreadLocal.withInitial(ThreadCache::new);\r\n\r\n    private ThreadBridge() {\r\n    }\r\n\r\n    static WorkerHandle current(TimelineLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        ThreadCache routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[236.245873, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[242.838377, "i", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\n"]
[242.839053, "o", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\r\n\u001b[?2004l\r"]
[242.840543, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\nimport java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final TimelineLedger revisions;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.revisions = new TimelineLedger(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        revisions.install(generation);\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public boolean isBalanced() {\r\n        return revisions.isBalanced();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        WorkerHandle binding = ThreadBridge.current(revisions);\r\n        return binding.process(record);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        revisions.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[242.840863, "o", "\u001b[?2004hroot@71fd5a51cd9b:/workspace/textd# "]
[248.952371, "i", "cat > src/main/java/io/harbor/textd/core/TextDaemon.java <<EOF\npackage io.harbor.textd.core;\n\nimport java.nio.file.Path;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.ExecutionException;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.Future;\nimport java.util.concurrent.ThreadFactory;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\n\npublic final class TextDaemon implements AutoCloseable {\n    private final ExecutorService workers;\n    private final TimelineLedger revisions;\n    private final int workerCount;\n\n    public TextDaemon(Path pluginJar, int workerCount) {\n        this.revisions = new TimelineLedger(pluginJar);\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\n        this.workerCount = workerCount;\n    }\n\n    public void reload(long generation) throws Exception {\n        revisions.install(generation);\n    }\n\n    public ProcessingResult process(String record) throws Exception {\n        return processBatch(List.of(record)).get(0);\n    } \n\n    public boolean isBalanced() {\n        return revisions.isBalanced();\n    }\n\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\n        CountDownLatch ready = new CountDownLatch(records.size());\n        CountDownLatch release = new CountDownLatch(1);\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\n        for (String record : records) {\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\n        }\n\n        if (!ready.await(5, TimeUnit.SECONDS)) {\n            throw new IllegalStateException(\"Workers did not become ready\");\n        }\n        release.countDown();\n\n        List<ProcessingResult> results = new ArrayList<>(records.size());\n        for (Future<ProcessingResult> future : futures) {\n            try {\n                results.add(future.get());\n            } catch (ExecutionException exception) {\n                Throwable cause = exception.getCause();\n                if (cause instanceof Exception checked) {\n                    throw checked;\n                }\n                if (cause instanceof Error error) {\n                    throw error;\n                }\n                throw new RuntimeException(cause);\n            }\n        }\n        return results;\n    }\n\n    private ProcessingResult processRecord(\n        String record,\n        CountDownLatch ready,\n        CountDownLatch release\n    ) throws Exception {\n        ready.countDown();\n        if (!release.await(5, TimeUnit.SECONDS)) {\n            throw new IllegalStateException(\"Request release timed out\");\n        }\n\n        WorkerHandle binding = ThreadBridge.current(revisions);\n        return binding.process(record);\n    }\n\n    @Override\n    public void close() throws Exception {\n        revisions.close();\n        workers.shutdownNow();\n        workers.awaitTermination(5, TimeUnit.SECONDS);\n    }\n\n    private static final class WorkerThreadFactory implements ThreadFactory {\n        private final AtomicInteger sequence = new AtomicInteger(1);\n\n        @Override\n        public Thread newThread(Runnable runnable) {\n            Thread thread = new Thread(() -> {\n                try {\n                    runnable.run();\n                } finally {\n                    ThreadBridge.clear();\n                }\n            });\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\n            thread.setDaemon(true);\n            return thread;\n        }\n    }\n}\nEOF\n"]
