[329.433539, "o", "  \"first\": {\"first\":\"GEN-001|ALPHA>BETA>GAMMA|PIPE-18528\",\"last\":\"GEN-004|ALPHA>BETA>GAMMA|PIPE-18528\",\"start\":[\"textd-worker-1\", \"textd-worker-2\", \"textd-worker-3\", \"textd-worker-4\"],\"end\":[\"textd-worker-1\", \"textd-worker-2\", \"textd-worker-3\", \"textd-worker-4\"],\"same_workers\":true,\"before_close\":true,\"after_close\":false,\"loaded_before_close\":694,\"loaded_after_close\":1861,\"unloaded_before_close\":0,\"unloaded_after_close\":0},\r\n"]
