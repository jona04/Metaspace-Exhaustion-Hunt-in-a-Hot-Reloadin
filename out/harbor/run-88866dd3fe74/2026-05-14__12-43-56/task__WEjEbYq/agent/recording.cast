[769.260263, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[769.260873, "o", "final class TimelineFrame {"]
[769.261084, "o", "\r\n"]
[769.263975, "o", "\u001b[?2004l\r\u001b[?2004h"]
[769.264068, "o", ">     private final LoadedGeneration loadedGeneration;"]
