[60.303906, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\nif [[ \"${TEXTD_SKIP_BUILD:-0}\" != \"1\" ]]; then\r\n  \"$ROOT_DIR/bin/build\"\r\nfi\r\n\r\nREPLAY_TMP=$(mktemp)\r\ntrap 'rm -f \"$REPLAY_TMP\"' EXIT\r\n\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.SessionReplayRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" 4 > \"$REPLAY_TMP\"\r\n\r\npython3 - \"$REPLAY_TMP\" <<'PYEOF'\r\nimport json, sys\r\n\r\nwith open(sys.argv[1]) as f:\r\n    data = json.load(f)\r\n\r\nfirst  = data['first']\r\nsecond = data['second']\r\n\r\nd1 = first['unloaded_after_close']  - first['unloaded_before_close']\r\nd2 = second['unloaded_after_close'] - second['unloaded_before_close']\r\n\r\nif d1 > 0 and d2 > 0:\r\n    print(f\"replay-ok unloaded-first={d1} unloaded-second={d2}\")\r\nelse:\r\n    print(f\"replay-fail unloaded-first={d1} unloaded-second={d2}\", file=sys.stderr)\r\n    sys.exit(1)\r\nPYEOF\r\n"]
