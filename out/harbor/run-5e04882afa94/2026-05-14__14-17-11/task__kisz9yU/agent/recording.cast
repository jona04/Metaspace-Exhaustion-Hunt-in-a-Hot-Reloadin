[646.108799, "o", "\r\n"]
[646.109559, "o", "\u001b[?2004l\r\u001b[?2004h> import java.util.List;\r\n\u001b[?2004l\r\u001b[?2004h> import java.util.concurrent.CountDownLatch;\r\n\u001b[?2004l\r\u001b[?2004h"]
