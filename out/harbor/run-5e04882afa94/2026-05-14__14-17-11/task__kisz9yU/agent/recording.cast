[646.115124, "o", "\r\n\u001b[?2004l\r"]
[646.115546, "o", "\u001b[?2004h> "]
[646.11566, "o", "    private final TimelineLedger revisions;"]
[646.115731, "o", "\r\n\u001b[?2004l\r"]
[646.116141, "o", "\u001b[?2004h"]
[646.116224, "o", ">     private final int workerCount;"]
[646.116381, "o", "\r\n\u001b[?2004l\r"]
[646.116733, "o", "\u001b[?2004h> "]
[646.117126, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.117204, "o", "    public TextDaemon(Path pluginJar, int workerCount) {"]
[646.117353, "o", "\r\n"]
[646.117617, "o", "\u001b[?2004l\r"]
[646.118014, "o", "\u001b[?2004h"]
[646.11819, "o", ">         this.revisions = new TimelineLedger(pluginJar);"]
[646.118329, "o", "\r\n"]
[646.118566, "o", "\u001b[?2004l\r"]
[646.119204, "o", "\u001b[?2004h"]
[646.119352, "o", ">         this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());"]
[646.119538, "o", "\r\n"]
[646.119688, "o", "\u001b[?2004l\r"]
[646.119924, "o", "\u001b[?2004h"]
[646.120055, "o", "> "]
[646.120442, "o", "        this.workerCount = workerCount;\r\n"]
[646.121045, "o", "\u001b[?2004l\r\u001b[?2004h"]
[646.121244, "o", ">     }"]
[646.121513, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[646.123639, "o", "\u001b[?2004h> "]
[646.124579, "o", "    public void reload(long generation) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h>         revisions.install(generation);\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.124795, "o", "> "]
[646.125154, "o", "    }\r\n"]
[646.1255, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[646.125805, "o", "\r\n"]
[646.127553, "o", "\u001b[?2004l\r\u001b[?2004h>     public ProcessingResult process(String record) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h>         return processBatch(List.of(record)).get(0);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[646.128022, "o", "\u001b[?2004h>     public boolean isBalanced() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.128268, "o", "        return revisions.isBalanced();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.128625, "o", "    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.129126, "o", "        CountDownLatch ready = new CountDownLatch(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.129766, "o", "        CountDownLatch release = new CountDownLatch(1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.129947, "o", "        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.130228, "o", "        for (String record : records) {\r\n\u001b[?2004l\r"]
[646.13051, "o", "\u001b[?2004h> "]
[646.130777, "o", "            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n\u001b[?2004l\r"]
[646.132571, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if (!ready.await(5, TimeUnit.SECONDS)) {\r\n\u001b[?2004l\r\u001b[?2004h>             throw new IllegalStateException(\"Workers did not become ready\");\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         release.countDown();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.13301, "o", "        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.133355, "o", "        for (Future<ProcessingResult> future : futures) {\r\n\u001b[?2004l\r"]
[646.13381, "o", "\u001b[?2004h>             try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.134152, "o", "                results.add(future.get());\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.13436, "o", "> "]
[646.134418, "o", "            } catch (ExecutionException exception) {\r\n"]
[646.134472, "o", "\u001b[?2004l\r"]
[646.134519, "o", "\u001b[?2004h"]
[646.134558, "o", "> "]
[646.135135, "o", "                Throwable cause = exception.getCause();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.135557, "o", "                if (cause instanceof Exception checked) {\r\n\u001b[?2004l\r"]
[646.136181, "o", "\u001b[?2004h>                     throw checked;\r\n\u001b[?2004l\r\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.136546, "o", "                if (cause instanceof Error error) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.136633, "o", "                    throw error;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.136849, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.137188, "o", "                throw new RuntimeException(cause);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.137384, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.137562, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>         return results;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[646.137711, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.137969, "o", "    private ProcessingResult processRecord(\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.138027, "o", "> "]
[646.138214, "o", "        String record,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.138413, "o", "        CountDownLatch ready,\r\n\u001b[?2004l\r"]
[646.138539, "o", "\u001b[?2004h> "]
[646.138672, "o", "        CountDownLatch release\r\n\u001b[?2004l\r"]
[646.138719, "o", "\u001b[?2004h> "]
[646.138887, "o", "    ) throws Exception {\r\n\u001b[?2004l\r"]
[646.138945, "o", "\u001b[?2004h> "]
[646.139124, "o", "        ready.countDown();\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.139169, "o", "> "]
[646.139612, "o", "        if (!release.await(5, TimeUnit.SECONDS)) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.139985, "o", "            throw new IllegalStateException(\"Request release timed out\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.140063, "o", ">         }\r\n\u001b[?2004l\r"]
[646.140175, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[646.140234, "o", "> "]
[646.140934, "o", "        WorkerHandle binding = ThreadBridge.current(revisions);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.141225, "o", "        return binding.process(record);\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.141291, "o", "> "]
[646.141593, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     @Override\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.141928, "o", "    public void close() throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.142505, "o", "        CyclicBarrier barrier = new CyclicBarrier(workerCount + 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.142722, "o", "        for (int i = 0; i < workerCount; i++) {\r\n\u001b[?2004l\r"]
[646.142776, "o", "\u001b[?2004h> "]
[646.142991, "o", "            workers.submit(() -> {\r\n\u001b[?2004l\r"]
[646.143118, "o", "\u001b[?2004h> "]
[646.143178, "o", "                try {\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.143235, "o", "> "]
[646.143524, "o", "                    ThreadBridge.clear();\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.143641, "o", "> "]
[646.14391, "o", "                    barrier.await();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.144159, "o", "                } catch (Exception ignored) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.144402, "o", ">                 }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.144642, "o", "            });\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.144795, "o", "        try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.14499, "o", "            barrier.await(5, TimeUnit.SECONDS);\r\n\u001b[?2004l\r"]
[646.145194, "o", "\u001b[?2004h> "]
[646.14537, "o", "        } catch (Exception ignored) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.145513, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[646.146148, "o", ">         revisions.close();\r\n\u001b[?2004l\r\u001b[?2004h>         workers.shutdownNow();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.14632, "o", "        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n\u001b[?2004l\r"]
[646.146413, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[646.146453, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[646.146625, "o", "\u001b[?2004h> "]
[646.147073, "o", "    private static final class WorkerThreadFactory implements ThreadFactory {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.147589, "o", "        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[646.147656, "o", "\u001b[?2004h> "]
[646.14783, "o", "        @Override\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.147937, "o", "> "]
[646.148199, "o", "        public Thread newThread(Runnable runnable) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.148261, "o", "> "]
[646.148657, "o", "            Thread thread = new Thread(runnable);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.14905, "o", "            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.149112, "o", "> "]
[646.149319, "o", "            thread.setDaemon(true);\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.14949, "o", "> "]
[646.149536, "o", "            return thread;\r\n\u001b[?2004l\r"]
[646.149727, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.149841, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[646.149886, "o", "\u001b[?2004h"]
