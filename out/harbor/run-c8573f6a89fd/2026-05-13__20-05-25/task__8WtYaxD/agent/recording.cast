[77.94206, "i", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\n"]
[77.94379, "o", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java"]
[77.952431, "o", "\r\n\u001b[?2004l\r"]
[77.959721, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class TimelineLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();\r\n    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    TimelineLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));\r\n        TimelineFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    TimelineFrame current() {\r\n        TimelineFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isBalanced() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        TimelineFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(TimelineFrame::isDrained);\r\n    }\r\n}\r\n"]
[77.961238, "o", "\u001b[?2004hroot@bf4b83b1971c:/workspace/textd# "]
[78.475423, "i", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\n"]
[78.476234, "o", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java"]
[78.477387, "o", "\r\n\u001b[?2004l\r"]
[78.480352, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadBridge {\r\n    private static final ThreadLocal<ThreadCache> ROUTES = ThreadLocal.withInitial(ThreadCache::new);\r\n\r\n    private ThreadBridge() {\r\n    }\r\n\r\n    static WorkerHandle current(TimelineLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        ThreadCache routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[78.480746, "o", "\u001b[?2004h"]
[78.480952, "o", "root@bf4b83b1971c:/workspace/textd# "]
[78.916717, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[78.917387, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java"]
[78.918912, "o", "\r\n\u001b[?2004l\r"]
[78.928654, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[78.930241, "o", "\u001b[?2004h"]
[78.931254, "o", "root@bf4b83b1971c:/workspace/textd# "]
[83.46982, "i", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\n"]
[83.472635, "o", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java"]
[83.472792, "o", "\r\n\u001b[?2004l\r"]
[83.475554, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class WorkerHandle implements AutoCloseable {\r\n    private final TimelineFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    WorkerHandle(TimelineFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(TimelineFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[83.476925, "o", "\u001b[?2004h"]
[83.477467, "o", "root@bf4b83b1971c:/workspace/textd# "]
[83.811143, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[83.813751, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java"]
[83.813903, "o", "\r\n\u001b[?2004l\r"]
[83.815963, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[83.817564, "o", "\u001b[?2004h"]
[83.817806, "o", "root@bf4b83b1971c:/workspace/textd# "]
[84.253566, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[84.254532, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n\u001b[?2004l\r"]
[84.258293, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[84.258547, "o", "\u001b[?2004hroot@bf4b83b1971c:/workspace/textd# "]
[89.174921, "i", "cat > src/main/java/io/harbor/textd/core/ThreadCache.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class ThreadCache implements AutoCloseable {\n    private WorkerHandle cursor;\n\n    WorkerHandle cursorFor(TimelineLedger ledger) {\n        TimelineFrame frame = ledger.current();\n        if (cursor == null) {\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        if (!cursor.matches(frame)) {\n            cursor.close();\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
