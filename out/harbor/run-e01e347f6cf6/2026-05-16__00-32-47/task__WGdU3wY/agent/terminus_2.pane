[?2004l[?2004h>         for (String record : records) {
[?2004l[?2004h>             futures.add(workers.submit(() -> processRecord(record, ready, release)));
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         if (!ready.await(5, TimeUnit.SECONDS)) {
[?2004l[?2004h>             throw new IllegalStateException("Workers did not become ready");
[?2004l[?2004h>         }
[?2004l[?2004h>         release.countDown();
[?2004l[?2004h> 
[?2004l[?2004h>         List<ProcessingResult> results = new ArrayList<>(records.size());
[?2004l[?2004h>         for (Future<ProcessingResult> future : futures) {
[?2004l[?2004h>             try {
[?2004l[?2004h>                 results.add(future.get());
[?2004l[?2004h>             } catch (ExecutionException exception) {
[?2004l[?2004h>                 Throwable cause = exception.getCause();
[?2004l[?2004h>                 if (cause instanceof Exception checked) {
[?2004l[?2004h>                     throw checked;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 if (cause instanceof Error error) {
[?2004l[?2004h>                     throw error;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 throw new RuntimeException(cause);
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>         return results;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     private ProcessingResult processRecord(
[?2004l[?2004h>         String record,
[?2004l[?2004h>         CountDownLatch ready,
[?2004l[?2004h>         CountDownLatch release
[?2004l[?2004h>     ) throws Exception {
[?2004l[?2004h>         ready.countDown();
[?2004l[?2004h>         if (!release.await(5, TimeUnit.SECONDS)) {
[?2004l[?2004h>             throw new IllegalStateException("Request release timed out");
[?2004l[?2004h>         }
