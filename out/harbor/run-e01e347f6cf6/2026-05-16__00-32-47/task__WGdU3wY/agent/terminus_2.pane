[?2004l[?2004h> 
[?2004l[?2004h> public final class TextDaemon implements AutoCloseable {
[?2004l[?2004h>     private ExecutorService workers;
[?2004l[?2004h>     private TimelineLedger revisions;
[?2004l[?2004h>     private final int workerCount;
[?2004l[?2004h> 
[?2004l[?2004h>     public TextDaemon(Path pluginJar, int workerCount) {
