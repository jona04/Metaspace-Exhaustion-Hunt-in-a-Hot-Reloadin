import java.nio.file.Path;
import java.util.Queue;
import java.util.concurrent.ConcurrentLinkedQueue;
import java.util.concurrent.atomic.AtomicReference;

final class TimelineLedger {
    private final Path pluginJar;
    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();
    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();

    TimelineLedger(Path pluginJar) {
        this.pluginJar = pluginJar;
    }

    void install(long revision) throws Exception {
        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));
        TimelineFrame previous = current.getAndSet(next);
        if (previous != null) {
            shadow.add(previous);
            previous.cool();
            pruneShadow();
        }
    }

    TimelineFrame current() {
        TimelineFrame frame = current.get();
        if (frame == null) {
            throw new IllegalStateException("No plugin generation is loaded");
        }
        return frame;
    }

    boolean isBalanced() {
        pruneShadow();
        return shadow.isEmpty();
    }

    void close() {
        TimelineFrame frame = current.getAndSet(null);
        if (frame != null) {
            shadow.add(frame);
            frame.cool();
        }
        pruneShadow();
    }

    private void pruneShadow() {
        shadow.removeIf(TimelineFrame::isDrained);
    }
}
[?2004hroot@e95a4114ce6b:/workspace/textd# cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java
[?2004lpackage io.harbor.textd.cli;

import io.harbor.textd.core.OutputFormat;
import io.harbor.textd.core.ProcessingResult;
import io.harbor.textd.core.TextDaemon;

import java.nio.file.Path;
import java.util.List;

public final class HotReloadStressRunner {
    private static final String SAMPLE = "alpha beta gamma";

    private HotReloadStressRunner() {
    }

    public static void main(String[] args) throws Exception {
        Path pluginJar = Path.of(args[0]);
        int cycles = args.length > 1 ? Integer.parseInt(args[1]) : 500;

        try (TextDaemon daemon = new TextDaemon(pluginJar, 4)) {
            for (int generation = 1; generation <= cycles; generation++) {
                daemon.reload(generation);
                assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE)));
                assertOutput(generation, daemon.process(SAMPLE));
                if (generation % 3 == 0) {
                    assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE)));
                }
            }
        }

        System.out.println("stress-ok cycles=" + cycles);
    }

    private static void assertOutputs(long generation, List<ProcessingResult> results) {
        for (ProcessingResult result : results) {
            assertOutput(generation, result);
        }
    }

    private static void assertOutput(long generation, ProcessingResult result) {
        String expected = OutputFormat.expectedFor(generation, SAMPLE);
        if (!expected.equals(result.output())) {
            throw new IllegalStateException("Unexpected output at generation " + generation + ": " + result.output());
        }
    }
}
[?2004hroot@e95a4114ce6b:/workspace/textd# cat src/main/java/io/harbor/textd/cli/HotReloadIntegrationRunner.java
[?2004lpackage io.harbor.textd.cli;

import io.harbor.textd.core.OutputFormat;
import io.harbor.textd.core.ProcessingResult;
import io.harbor.textd.core.TextDaemon;

import java.nio.file.Path;
import java.util.List;
public final class HotReloadIntegrationRunner {
    private static final String SAMPLE = "alpha beta gamma";

    private HotReloadIntegrationRunner() {
    }

    public static void main(String[] args) throws Exception {
        Path pluginJar = Path.of(args[0]);
        int revision = args.length > 1 ? Integer.parseInt(args[1]) : 24;

        try (TextDaemon daemon = new TextDaemon(pluginJar, 4)) {
            daemon.reload(1);
            List<ProcessingResult> baselineResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));
            assertOutputs(1, baselineResults);

            List<ProcessingResult> currentResults = baselineResults;
            for (int current = 2; current <= revision; current++) {
                daemon.reload(current);
                currentResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));
                assertOutputs(current, currentResults);
            }

            String baseline = baselineResults.get(0).output();
            String current = currentResults.get(0).output();

            System.out.println("{");
            System.out.println("  \"input\": \"" + SAMPLE + "\",");
            System.out.println("  \"baseline\": \"" + baseline + "\",");
            System.out.println("  \"revision\": " + revision + ",");
            System.out.println("  \"current\": \"" + current + "\"");
            System.out.println("}");
        }
    }

    private static void assertOutputs(long revision, List<ProcessingResult> results) {
        String expected = OutputFormat.expectedFor(revision, SAMPLE);
        for (ProcessingResult result : results) {
            if (!expected.equals(result.output())) {
                throw new IllegalStateException("Unexpected output at revision " + revision + ": " + result.output());
            }
        }
    }
}
[?2004hroot@e95a4114ce6b:/workspace/textd# cat src/main/java/io/harbor/textd/cli/RuntimeDigestRunner.java
[?2004lpackage io.harbor.textd.cli;

import io.harbor.textd.core.OutputFormat;
import io.harbor.textd.core.ProcessingResult;
import io.harbor.textd.core.TextDaemon;

import java.nio.file.Path;
import java.util.List;
import java.util.stream.Collectors;

public final class RuntimeDigestRunner {
    private static final String SAMPLE = "alpha beta gamma";

    private RuntimeDigestRunner() {
    }

    public static void main(String[] args) throws Exception {
        Path pluginJar = Path.of(args[0]);
        int revision = args.length > 1 ? Integer.parseInt(args[1]) : 24;

        TextDaemon daemon = new TextDaemon(pluginJar, 4);
        try {
            daemon.reload(1);
            List<ProcessingResult> firstResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));
            assertOutputs(1, firstResults);

            List<String> workersStart = firstResults.stream()
                .map(ProcessingResult::workerThread)
                .sorted()
                .collect(Collectors.toList());

            List<ProcessingResult> finalResults = firstResults;
            for (int current = 2; current <= revision; current++) {
                daemon.reload(current);
                finalResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));
                assertOutputs(current, finalResults);
            }

            List<String> workersEnd = finalResults.stream()
                .map(ProcessingResult::workerThread)
                .sorted()
                .collect(Collectors.toList());

            boolean sameWorkers = workersStart.equals(workersEnd);
            boolean beforeClose = daemon.isBalanced();
            String first = firstResults.get(0).output();
            String last = finalResults.get(0).output();

            daemon.close();
            boolean afterClose = daemon.isBalanced();

            System.out.println("{");
            System.out.println("  \"sample\": \"" + SAMPLE + "\",");
            System.out.println("  \"first\": \"" + first + "\",");
            System.out.println("  \"rev\": " + revision + ",");
            System.out.println("  \"last\": \"" + last + "\",");
            System.out.println("  \"start\": " + toJsonArray(workersStart) + ",");
            System.out.println("  \"end\": " + toJsonArray(workersEnd) + ",");
            System.out.println("  \"same_workers\": " + sameWorkers + ",");
            System.out.println("  \"before_close\": " + beforeClose + ",");
            System.out.println("  \"after_close\": " + afterClose);
            System.out.println("}");
        } catch (Exception exception) {
            try {
                daemon.close();
            } catch (Exception closeException) {
                exception.addSuppressed(closeException);
            }
            throw exception;
        }
    }

    private static void assertOutputs(long revision, List<ProcessingResult> results) {
        String expected = OutputFormat.expectedFor(revision, SAMPLE);
        for (ProcessingResult result : results) {
            if (!expected.equals(result.output())) {
                throw new IllegalStateException("Unexpected output at revision " + revision + ": " + result.output());
            }
        }
    }

    private static String toJsonArray(List<String> values) {
        return values.stream()
            .map(value -> "\"" + value + "\"")
            .collect(Collectors.joining(", ", "[", "]"));
    }
}
