[9.777696, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n\u001b[?2004l\r"]
[9.779557, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[9.77984, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[9.975118, "i", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\n"]
[9.975724, "o", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\r\n\u001b[?2004l\r"]
[9.977076, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\nimport java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final TimelineLedger revisions;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.revisions = new TimelineLedger(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        revisions.install(generation);\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public boolean isBalanced() {\r\n        return revisions.isBalanced();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        WorkerHandle binding = ThreadBridge.current(revisions);\r\n        return binding.process(record);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        revisions.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[9.977387, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[14.31366, "i", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\n"]
[14.314207, "o", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\r\n\u001b[?2004l\r"]
[14.316559, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class TimelineLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();\r\n    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    TimelineLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));\r\n        TimelineFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    TimelineFrame current() {\r\n        TimelineFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isBalanced() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        TimelineFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(TimelineFrame::isDrained);\r\n    }\r\n}\r\n"]
[14.31687, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[14.49443, "i", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\n"]
[14.495667, "o", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\r\n\u001b[?2004l\r"]
[14.497511, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadBridge {\r\n    private static final ThreadLocal<ThreadCache> ROUTES = ThreadLocal.withInitial(ThreadCache::new);\r\n\r\n    private ThreadBridge() {\r\n    }\r\n\r\n    static WorkerHandle current(TimelineLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        ThreadCache routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[14.497938, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[14.715442, "i", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\n"]
[14.716014, "o", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\r\n\u001b[?2004l\r"]
[14.717268, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class WorkerHandle implements AutoCloseable {\r\n    private final TimelineFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    WorkerHandle(TimelineFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(TimelineFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[14.717681, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[17.318751, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[17.319356, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\r\n\u001b[?2004l\r"]
[17.320988, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[17.321501, "o", "\u001b[?2004hroot@fe41cefacffe:/workspace/textd# "]
[17.523481, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[17.524258, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[17.52804, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
