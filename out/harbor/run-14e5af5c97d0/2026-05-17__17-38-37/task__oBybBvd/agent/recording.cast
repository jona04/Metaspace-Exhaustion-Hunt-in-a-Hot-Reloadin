[86.209917, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[86.210557, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[86.213398, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            if (cursor != null) cursor.close(); cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            if (cursor != null) cursor.close(); cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[86.213757, "o", "\u001b[?2004hroot@1fe1bb1dde48:/workspace/textd# "]
[86.370589, "i", "bin/run-suite\n"]
[86.370949, "o", "bin/run-suite\r\n\u001b[?2004l\r"]
[116.413965, "o", "suite-ok\r\n"]
[116.414755, "o", "\u001b[?2004hroot@1fe1bb1dde48:/workspace/textd# "]
