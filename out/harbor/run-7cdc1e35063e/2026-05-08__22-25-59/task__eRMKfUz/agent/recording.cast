[28.300468, "o", "package io.harbor.textd.core;\r\n\r\nimport java.util.ArrayDeque;\r\nimport java.util.Deque;\r\n\r\nfinal class WorkerState {\r\n    private static final ThreadLocal<Deque<Object>> ACTIVE_MODULES = ThreadLocal.withInitial(ArrayDeque::new);\r\n\r\n    private WorkerState() {\r\n    }\r\n\r\n    static Scope attach(Object module) {\r\n        ACTIVE_MODULES.get().push(module);\r\n        return new Scope();\r\n    }\r\n\r\n    static final class Scope implements AutoCloseable {\r\n        @Override\r\n        public void close() {\r\n        }\r\n    }\r\n}\r\n"]
[28.300815, "o", "\u001b[?2004hroot@54160cd22210:/workspace/textd# "]
[41.164566, "i", "cat > src/main/java/io/harbor/textd/core/WorkerState.java <<EOF\npackage io.harbor.textd.core;\n\nimport java.util.ArrayDeque;\nimport java.util.Deque;\n\nfinal class WorkerState {\n    private static final ThreadLocal<Deque<Object>> ACTIVE_MODULES = ThreadLocal.withInitial(ArrayDeque::new);\n\n    private WorkerState() {\n    }\n\n    static Scope attach(Object module) {\n        ACTIVE_MODULES.get().push(module);\n        return new Scope();\n    }\n\n    static final class Scope implements AutoCloseable {\n        @Override\n        public void close() {\n            ACTIVE_MODULES.get().pop();\n        }\n    }\n}\nEOF\n"]
