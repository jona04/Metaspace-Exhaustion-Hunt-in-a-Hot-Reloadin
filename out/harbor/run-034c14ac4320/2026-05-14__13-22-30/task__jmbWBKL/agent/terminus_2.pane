[?2004l#!/bin/bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
BUILD_DIR="$ROOT_DIR/build"
MAIN_CLASSES="$BUILD_DIR/main-classes"
PLUGIN_CLASSES="$BUILD_DIR/plugin-classes"
PLUGIN_DIR="$BUILD_DIR/plugins"

rm -rf "$MAIN_CLASSES" "$PLUGIN_CLASSES"
mkdir -p "$MAIN_CLASSES" "$PLUGIN_CLASSES" "$PLUGIN_DIR"

find "$ROOT_DIR/src/main/java" -name '*.java' | sort > "$BUILD_DIR/main-sources.txt"
javac --release 17 -d "$MAIN_CLASSES" @"$BUILD_DIR/main-sources.txt"

find "$ROOT_DIR/plugin-src" -name '*.java' | sort > "$BUILD_DIR/plugin-sources.txt"
javac --release 17 -cp "$MAIN_CLASSES" -d "$PLUGIN_CLASSES" @"$BUILD_DIR/plugin-sources.txt"

jar --create --file "$PLUGIN_DIR/customer-default.jar" -C "$PLUGIN_CLASSES" .
[?2004hroot@d08983370c6e:/workspace/textd# cat src/main/java/io/harbor/textd/core/OutputFormat.java
[?2004lpackage io.harbor.textd.core;

import java.util.Arrays;
import java.util.Locale;
import java.util.stream.Collectors;

public final class OutputFormat {
    private static final int PIPELINE_WEIGHT = 18528;

    private OutputFormat() {
    }

    public static String expectedFor(long generation, String record) {
        String normalized = Arrays.stream(record.trim().split("\\s+"))
            .filter(token -> !token.isBlank())
            .map(token -> token.toUpperCase(Locale.ROOT))
            .collect(Collectors.joining(">"));
        return String.format(Locale.ROOT, "GEN-%03d|%s|PIPE-%d", generation, normalized, PIPELINE_WEIGHT);
    }
}
