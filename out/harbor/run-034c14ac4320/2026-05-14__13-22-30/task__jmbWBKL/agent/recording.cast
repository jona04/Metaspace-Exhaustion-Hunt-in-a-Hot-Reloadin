[546.098958, "o", "    private final AtomicInteger pins = new AtomicInteger(1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.099461, "o", "    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.099762, "o", "    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.099927, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.100238, "o", "    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.100285, "o", "> "]
[546.100583, "o", "        this.loadedGeneration = loadedGeneration;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.101022, "o", "        this.revision = loadedGeneration.generation();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.101096, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.101264, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.101319, "o", "    TimelineFrame pin() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.10151, "o", "        while (true) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.101584, "o", "> "]
[546.101779, "o", "            int current = pins.get();\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.101933, "o", "> "]
[546.102011, "o", "            if (current == 0) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.102053, "o", "> "]
[546.102691, "o", "                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.102814, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.103015, "o", "> "]
[546.103257, "o", "            if (pins.compareAndSet(current, current + 1)) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.103372, "o", "> "]
[546.103498, "o", "                return this;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.103623, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.10367, "o", "> "]
[546.103945, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.10408, "o", "    long revision() {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.104192, "o", "> "]
[546.104309, "o", "        return revision;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.104675, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     PluginModule module() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.105054, "o", "        LoadedGeneration gen = loadedGeneration;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.107993, "o", "        if (gen == null) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.108066, "o", ">             throw new IllegalStateException(\"Revision \" + revision + \" is already closed\");\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>         return gen.module();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     void cool() {\r\n\u001b[?2004l\r\u001b[?2004h>         if (cooled.compareAndSet(false, true)) {\r\n\u001b[?2004l\r\u001b[?2004h>             unpin();\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.108105, "o", "> "]
[546.108149, "o", "    }\r\n\u001b[?2004l\r"]
[546.108658, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     void unpin() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.108889, "o", "        int remaining = pins.decrementAndGet();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.110158, "o", "        if (remaining < 0) {\r\n\u001b[?2004l\r"]
[546.110209, "o", "\u001b[?2004h"]
[546.110253, "o", "> "]
[546.11086, "o", "            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n\u001b[?2004l\r"]
[546.110989, "o", "\u001b[?2004h> "]
[546.111029, "o", "        }\r\n\u001b[?2004l\r"]
[546.111073, "o", "\u001b[?2004h"]
[546.11111, "o", "> "]
[546.111469, "o", "        if (remaining == 0 && cooled.get()) {\r\n"]
[546.11306, "o", "\u001b[?2004l\r\u001b[?2004h>             closeLoadedGeneration();\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     boolean isDrained() {\r\n\u001b[?2004l\r\u001b[?2004h>         return closed.get();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     private void closeLoadedGeneration() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.113106, "o", "        if (closed.compareAndSet(false, true)) {\r\n\u001b[?2004l\r"]
[546.113138, "o", "\u001b[?2004h"]
[546.113177, "o", "> "]
[546.113612, "o", "            try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.113663, "o", "                loadedGeneration.close();\r\n\u001b[?2004l\r"]
[546.113701, "o", "\u001b[?2004h"]
[546.113741, "o", "> "]
[546.114104, "o", "                loadedGeneration = null;"]
[546.114208, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.114251, "o", "> "]
[546.114536, "o", "            } catch (Exception exception) {"]
[546.114661, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.115306, "o", "                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);"]
[546.116058, "o", "\r\n\u001b[?2004l\r"]
[546.116107, "o", "\u001b[?2004h> "]
[546.116324, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.116372, "o", "    }\r\n\u001b[?2004l\r"]
[546.116413, "o", "\u001b[?2004h> }"]
