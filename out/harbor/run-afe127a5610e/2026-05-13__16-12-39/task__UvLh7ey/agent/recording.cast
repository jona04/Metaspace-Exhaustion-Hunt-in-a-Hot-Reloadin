[687.249434, "i", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\n"]
[687.250752, "o", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\r\n\u001b[?2004l\r"]
[687.253242, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class WorkerHandle implements AutoCloseable {\r\n    private final TimelineFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    WorkerHandle(TimelineFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(TimelineFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[687.253791, "o", "\u001b[?2004hroot@f790fa64ce73:/workspace/textd# "]
[687.494458, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[687.496293, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java"]
[687.497963, "o", "\r\n\u001b[?2004l\r"]
[687.502546, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[687.504125, "o", "\u001b[?2004hroot@f790fa64ce73:/workspace/textd# "]
[687.77664, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[687.777608, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java"]
[687.7781, "o", "\r\n\u001b[?2004l\r"]
[687.780557, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[687.781725, "o", "\u001b[?2004hroot@f790fa64ce73:/workspace/textd# "]
[693.185991, "i", "cat > src/main/java/io/harbor/textd/core/ThreadCache.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class ThreadCache implements AutoCloseable {\n    private WorkerHandle cursor;\n\n    WorkerHandle cursorFor(TimelineLedger ledger) {\n        TimelineFrame frame = ledger.current();\n        if (cursor == null) {\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        if (!cursor.matches(frame)) {\n            cursor.close();\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
[693.187072, "o", "cat > src/main/java/io/harbor/textd/core/ThreadCache.java <<EOF"]
