[231.273099, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor.close();\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[231.273598, "o", "\u001b[?2004h"]
[231.273901, "o", "root@7c6870e4830b:/workspace/textd# "]
