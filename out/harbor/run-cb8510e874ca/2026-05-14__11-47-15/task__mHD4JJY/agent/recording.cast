[281.067736, "o", "\u001b[?2004h> "]
[281.068134, "o", "        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.068478, "o", "        for (Future<ProcessingResult> future : futures) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.068636, "o", "            try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.068921, "o", "                results.add(future.get());\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.069291, "o", ">             } catch (ExecutionException exception) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.069492, "o", "> "]
[281.069643, "o", "                Throwable cause = exception.getCause();\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.069813, "o", "> "]
[281.070019, "o", "                if (cause instanceof Exception checked) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.070168, "o", "> "]
[281.070262, "o", "                    throw checked;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.070403, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.070596, "o", "> "]
