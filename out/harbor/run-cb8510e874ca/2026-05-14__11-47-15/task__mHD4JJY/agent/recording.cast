[281.078973, "o", "            try {\r\n\u001b[?2004l\r\u001b[?2004h>                 cleanup.get(1, TimeUnit.SECONDS);\r\n\u001b[?2004l\r\u001b[?2004h>             } catch (Exception ignored) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.079109, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.07924, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
