[281.08045, "o", "    private static final class WorkerThreadFactory implements ThreadFactory {\r\n\u001b[?2004l\r"]
[281.080591, "o", "\u001b[?2004h> "]
[281.080948, "o", "        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.081026, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[281.081077, "o", "> "]
[281.081158, "o", "        @Override\r\n\u001b[?2004l\r"]
[281.081301, "o", "\u001b[?2004h> "]
[281.081571, "o", "        public Thread newThread(Runnable runnable) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.081717, "o", "> "]
[281.082117, "o", "            Thread thread = new Thread(runnable);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.08246, "o", "            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.082677, "o", "            thread.setDaemon(true);\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.082742, "o", "> "]
