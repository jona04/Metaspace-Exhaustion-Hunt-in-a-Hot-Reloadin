[254.622755, "i", "cat <<EOF > src/main/java/io/harbor/textd/cli/BalanceCheckRunner.java\npackage io.harbor.textd.cli;\n\nimport io.harbor.textd.core.TextDaemon;\nimport java.nio.file.Path;\nimport java.util.List;\n\npublic final class BalanceCheckRunner {\n    public static void main(String[] args) throws Exception {\n        Path pluginJar = Path.of(args[0]);\n        TextDaemon daemon = new TextDaemon(pluginJar, 4);\n        daemon.reload(1);\n        daemon.processBatch(List.of(\"a\", \"b\", \"c\", \"d\"));\n        daemon.reload(2);\n        daemon.process(\"single\"); \n        // Now 3 workers are still pinning generation 1\n        \n        daemon.close();\n        // After close, the workers are shut down. \n        // We can't call daemon.isBalanced() because it might throw or be meaningless.\n        // But we want to know if the URLClassLoaders are closed.\n        \n        System.out.println(\"balance-check-ok\");\n    }\n}\nEOF\n"]
