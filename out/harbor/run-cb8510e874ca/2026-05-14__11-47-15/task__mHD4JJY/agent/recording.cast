[281.075936, "o", "    @Override\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.076321, "o", "    public void close() throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.076499, "o", "> "]
[281.076557, "o", "        revisions.close();\r\n\u001b[?2004l\r"]
[281.077589, "o", "\u001b[?2004h>         List<Future<?>> cleanups = new ArrayList<>();\r\n\u001b[?2004l\r\u001b[?2004h>         for (int i = 0; i < workerCount; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>             cleanups.add(workers.submit(ThreadBridge::clear));\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.078033, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
