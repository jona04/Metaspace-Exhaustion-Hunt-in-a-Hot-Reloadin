[281.0743, "o", "\u001b[?2004h> "]
[281.07436, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.074405, "o", "> \r\n\u001b[?2004l\r"]
[281.074452, "o", "\u001b[?2004h> "]
[281.074933, "o", "        WorkerHandle binding = ThreadBridge.current(revisions);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[281.075172, "o", "        return binding.process(record);\r\n\u001b[?2004l\r"]
[281.075229, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
