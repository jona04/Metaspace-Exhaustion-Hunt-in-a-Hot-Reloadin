(Future<ProcessingResult> future : futures) {\n            try {\n                results.add(future.get());\n            } catch (ExecutionException exception) {\n                Throwable cause = exception.getCause();\n                if (cause instanceof Exception checked) {\n                    throw checked;\n                }\n                if (cause instanceof Error error) {\n                    throw error;\n                }\n                throw new RuntimeException(cause);\n            }\n        }\n        return results;\n    }\n\n    private ProcessingResult processRecord(\n        String record,\n        CountDownLatch ready,\n        CountDownLatch release\n    ) throws Exception {\n        ready.countDown();\n        if (!release.await(5, TimeUnit.SECONDS)) {\n            throw new IllegalStateException("Request release timed out");\n        }\n\n        WorkerHandle binding = ThreadBridge.current(revisions);\n        return binding.process(record);\n    }\n\n    @Override\n    public void close() throws Exception {\n        List<Future<?>> clearances = new ArrayList<>();\n        for (int i = 0; i < workerCount; i++) {\n            clearances.add(workers.submit(ThreadBridge::clear));\n        }\n        for (Future<?> clearance : clearances) {\n            clearance.get(5, TimeUnit.SECONDS);\n        }\n\n        revisions.close();\n        workers.shutdownNow();\n        workers.awaitTermination(5, TimeUnit.SECONDS);\n    }\n\n    private static final class WorkerThreadFactory implements ThreadFactory {\n        private final AtomicInteger sequence = new AtomicInteger(1);\n\n        @Override\n        public Thread newThread(Runnable runnable) {\n            Thread thread = new Thread(runnable);\n            thread.setName("textd-worker-" + sequence.getAndIncrement());\n            thread.setDaemon(true);\n            return thread;\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat <<EOF > src/main/java/io/harbor/textd/core/TimelineFrame.java\npackage io.harbor.textd.core;\n\nimport io.harbor.textd.api.PluginModule;\n\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nfinal class TimelineFrame {\n    private LoadedGeneration loadedGeneration;\n    private final long revision;\n    private final AtomicInteger pins = new AtomicInteger(1);\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\n    private final AtomicBoolean closed = new AtomicBoolean(false);\n\n    TimelineFrame(LoadedGeneration loadedGeneration) {\n        this.loadedGeneration = loadedGeneration;\n        this.revision = loadedGeneration.generation();\n    }\n\n    TimelineFrame pin() {\n        while (true) {\n            int current = pins.get();\n            if (current == 0) {\n                throw new IllegalStateException("Revision " + revision + " is already closed");\n            }\n            if (pins.compareAndSet(current, current + 1)) {\n                return this;\n            }\n        }\n    }\n\n    long revision() {\n        return revision;\n    }\n\n    PluginModule module() {\n        return loadedGeneration.module();\n    }\n\n    void cool() {\n        if (cooled.compareAndSet(false, true)) {\n            unpin();\n        }\n    }\n\n    void unpin() {\n        int remaining = pins.decrementAndGet();\n        if (remaining < 0) {\n            throw new IllegalStateException("Pin count underflow for revision " + revision);\n        }\n        if (remaining == 0 && cooled.get()) {\n            closeLoadedGeneration();\n        }\n    }\n\n    boolean isDrained() {\n        return closed.get();\n    }\n\n    private void closeLoadedGeneration() {\n        if (closed.compareAndSet(false, true)) {\n            try {\n                loadedGeneration.close();\n                loadedGeneration = null;\n            } catch (Exception exception) {\n                throw new IllegalStateException("Unable to close revision " + revision, exception);\n            }\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
