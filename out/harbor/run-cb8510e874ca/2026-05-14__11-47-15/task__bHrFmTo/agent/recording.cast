[361.545361, "i", "cat plugin-src/io/harbor/textd/customer/PipelineProcessor.java\n"]
[361.546598, "o", "cat plugin-src/io/harbor/textd/customer/PipelineProcessor.java\r\n\u001b[?2004l\r"]
[361.548759, "o", "package io.harbor.textd.customer;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nimport java.util.Arrays;\r\nimport java.util.Locale;\r\nimport java.util.stream.Collectors;\r\n\r\npublic final class PipelineProcessor implements TextProcessor {\r\n    private final long generation;\r\n\r\n    public PipelineProcessor(long generation) {\r\n        this.generation = generation;\r\n    }\r\n\r\n    @Override\r\n    public String process(String record) {\r\n        String normalized = Arrays.stream(record.trim().split(\"\\\\s+\"))\r\n            .filter(token -> !token.isBlank())\r\n            .map(token -> token.toUpperCase(Locale.ROOT))\r\n            .collect(Collectors.joining(\">\"));\r\n        return String.format(Locale.ROOT, \"GEN-%03d|%s|PIPE-%d\", generation, normalized, PipelineStages.pipelineWeight());\r\n    }\r\n}\r\n"]
[361.549945, "o", "\u001b[?2004hroot@138f0c73e14a:/workspace/textd# "]
[373.814792, "i", "cat <<EOF > src/main/java/io/harbor/textd/core/LoadedGeneration.java\npackage io.harbor.textd.core;\n\nimport io.harbor.textd.api.PluginModule;\nimport io.harbor.textd.api.PluginModuleFactory;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Path;\n\nfinal class LoadedGeneration implements AutoCloseable {\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\n\n    private final long generation;\n    private URLClassLoader classLoader;\n    private PluginModule module;\n\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\n        this.generation = generation;\n        this.classLoader = classLoader;\n        this.module = module;\n    }\n\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\n        return new LoadedGeneration(generation, classLoader, factory.open());\n    }\n\n    long generation() {\n        return generation;\n    }\n\n    PluginModule module() {\n        return module;\n    }\n\n    @Override\n    public void close() throws Exception {\n        if (module != null) {\n            module.close();\n            module = null;\n        }\n        if (classLoader != null) {\n            classLoader.close();\n            classLoader = null;\n        }\n    }\n}\nEOF\n"]
