[48.675261, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\nBUILD_DIR=\"$ROOT_DIR/build\"\r\nMAIN_CLASSES=\"$BUILD_DIR/main-classes\"\r\nPLUGIN_CLASSES=\"$BUILD_DIR/plugin-classes\"\r\nPLUGIN_DIR=\"$BUILD_DIR/plugins\"\r\n\r\nrm -rf \"$MAIN_CLASSES\" \"$PLUGIN_CLASSES\"\r\nmkdir -p \"$MAIN_CLASSES\" \"$PLUGIN_CLASSES\" \"$PLUGIN_DIR\"\r\n\r\nfind \"$ROOT_DIR/src/main/java\" -name '*.java' | sort > \"$BUILD_DIR/main-sources.txt\"\r\njavac --release 17 -d \"$MAIN_CLASSES\" @\"$BUILD_DIR/main-sources.txt\"\r\n\r\nfind \"$ROOT_DIR/plugin-src\" -name '*.java' | sort > \"$BUILD_DIR/plugin-sources.txt\"\r\njavac --release 17 -cp \"$MAIN_CLASSES\" -d \"$PLUGIN_CLASSES\" @\"$BUILD_DIR/plugin-sources.txt\"\r\n\r\njar --create --file \"$PLUGIN_DIR/customer-default.jar\" -C \"$PLUGIN_CLASSES\" .\r\n"]
[48.675549, "o", "\u001b[?2004hroot@574485af7992:/workspace/textd# "]
[51.512045, "i", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\n"]
[51.512637, "o", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\r\n\u001b[?2004l\r"]
[51.514444, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\n\r\npublic final class HotReloadStressRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n\r\n    private HotReloadStressRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int cycles = args.length > 1 ? Integer.parseInt(args[1]) : 500;\r\n\r\n        try (TextDaemon daemon = new TextDaemon(pluginJar, 2)) {\r\n            for (int generation = 1; generation <= cycles; generation++) {\r\n                daemon.reload(generation);\r\n                List<ProcessingResult> results = daemon.processBatch(List.of(SAMPLE, SAMPLE));\r\n                String expected = OutputFormat.expectedFor(generation, SAMPLE);\r\n                for (ProcessingResult result : results) {\r\n                    if (!expected.equals(result.output())) {\r\n                        throw new IllegalStateException(\"Unexpected output at generation \" + generation + \": \" + result.output());\r\n                    }\r\n                }\r\n            }\r\n        }\r\n\r\n        System.out.println(\"stress-ok cycles=\" + cycles);\r\n    }\r\n}\r\n"]
[51.514704, "o", "\u001b[?2004hroot@574485af7992:/workspace/textd# "]
[51.700235, "i", "./bin/stress 1000\n"]
[51.700865, "o", "./bin/stress 1000\r\n\u001b[?2004l\r"]
[81.131686, "o", "stress-ok cycles=1000\r\n"]
