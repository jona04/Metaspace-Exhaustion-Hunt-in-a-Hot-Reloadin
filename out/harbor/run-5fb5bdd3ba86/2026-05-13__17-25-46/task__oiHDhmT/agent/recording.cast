[558.463513, "i", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\n"]
[558.464318, "o", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\r\n\u001b[?2004l\r"]
[558.466556, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class TimelineLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();\r\n    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    TimelineLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));\r\n        TimelineFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    TimelineFrame current() {\r\n        TimelineFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isBalanced() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        TimelineFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(TimelineFrame::isDrained);\r\n    }\r\n}\r\n"]
[558.466846, "o", "\u001b[?2004hroot@971e08761e6a:/workspace/textd# "]
[558.967534, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[558.969584, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java"]
[558.976244, "o", "\r\n"]
[558.97694, "o", "\u001b[?2004l\r"]
[558.978525, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n\u001b[?2004h"]
[558.980381, "o", "root@971e08761e6a:/workspace/textd# "]
[563.483237, "i", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\n"]
[563.484918, "o", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java"]
[563.486199, "o", "\r\n\u001b[?2004l\r"]
[563.488036, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class WorkerHandle implements AutoCloseable {\r\n    private final TimelineFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    WorkerHandle(TimelineFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(TimelineFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[563.488173, "o", "\u001b[?2004hroot@971e08761e6a:/workspace/textd# "]
[563.968327, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[563.969702, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\r\n\u001b[?2004l\r"]
[563.971952, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[563.972742, "o", "\u001b[?2004hroot@971e08761e6a:/workspace/textd# "]
[564.482499, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[564.483956, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n"]
[564.484712, "o", "\u001b[?2004l\r"]
[564.486572, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[564.48751, "o", "\u001b[?2004hroot@971e08761e6a:/workspace/textd# "]
[571.620367, "i", "cat > src/main/java/io/harbor/textd/core/ThreadCache.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class ThreadCache implements AutoCloseable {\n    private WorkerHandle cursor;\n\n    WorkerHandle cursorFor(TimelineLedger ledger) {\n        TimelineFrame frame = ledger.current();\n        if (cursor == null) {\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        if (!cursor.matches(frame)) {\n            cursor.close();\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
