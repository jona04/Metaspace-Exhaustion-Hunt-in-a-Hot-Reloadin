[149.909709, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\n\"$ROOT_DIR/bin/build\"\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/integration\" 24 >/tmp/textd-integration.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.RuntimeDigestRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-session.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.SessionReplayRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-replay.json\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/stress\" 500 >/tmp/textd-stress.log\r\n\r\necho \"suite-ok\"\r\n"]
