[6.76729, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\nBUILD_DIR=\"$ROOT_DIR/build\"\r\nMAIN_CLASSES=\"$BUILD_DIR/main-classes\"\r\nPLUGIN_CLASSES=\"$BUILD_DIR/plugin-classes\"\r\nPLUGIN_DIR=\"$BUILD_DIR/plugins\"\r\n\r\nrm -rf \"$MAIN_CLASSES\" \"$PLUGIN_CLASSES\"\r\nmkdir -p \"$MAIN_CLASSES\" \"$PLUGIN_CLASSES\" \"$PLUGIN_DIR\"\r\n\r\nfind \"$ROOT_DIR/src/main/java\" -name '*.java' | sort > \"$BUILD_DIR/main-sources.txt\"\r\njavac --release 17 -d \"$MAIN_CLASSES\" @\"$BUILD_DIR/main-sources.txt\"\r\n\r\nfind \"$ROOT_DIR/plugin-src\" -name '*.java' | sort > \"$BUILD_DIR/plugin-sources.txt\"\r\njavac --release 17 -cp \"$MAIN_CLASSES\" -d \"$PLUGIN_CLASSES\" @\"$BUILD_DIR/plugin-sources.txt\"\r\n\r\njar --create --file \"$PLUGIN_DIR/customer-default.jar\" -C \"$PLUGIN_CLASSES\" .\r\n"]
