[279.363973, "o", "        release.countDown();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.364318, "o", "        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.364659, "o", "        for (Future<ProcessingResult> future : futures) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.364828, "o", "            try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.365164, "o", "                results.add(future.get());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.365487, "o", "            } catch (ExecutionException exception) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.365804, "o", "                Throwable cause = exception.getCause();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.366154, "o", "                if (cause instanceof Exception checked) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.366282, "o", "                    throw checked;\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.366355, "o", "> "]
[279.366445, "o", "                }\r\n\u001b[?2004l\r"]
[279.36653, "o", "\u001b[?2004h> "]
[279.36683, "o", "                if (cause instanceof Error error) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.367003, "o", "                    throw error;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.367275, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.367508, "o", "                throw new RuntimeException(cause);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.36757, "o", "            }\r\n\u001b[?2004l\r"]
[279.367614, "o", "\u001b[?2004h> "]
[279.367799, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.367903, "o", ">         return results;\r\n\u001b[?2004l\r"]
[279.368017, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.368121, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[279.369207, "o", "> "]
[279.369317, "o", "    private ProcessingResult processRecord(\r\n\u001b[?2004l\r\u001b[?2004h>         String record,\r\n\u001b[?2004l\r\u001b[?2004h>         CountDownLatch ready,\r\n\u001b[?2004l\r\u001b[?2004h>         CountDownLatch release\r\n\u001b[?2004l\r\u001b[?2004h>     ) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h>         ready.countDown();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.369585, "o", "        if (!release.await(5, TimeUnit.SECONDS)) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.369846, "o", "> "]
[279.370001, "o", "            throw new IllegalStateException(\"Request release timed out\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.370126, "o", "> "]
[279.370483, "o", "        }\r\n\u001b[?2004l\r"]
[279.370557, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.370731, "o", "        WorkerHandle binding = ThreadBridge.current(revisions);\r\n\u001b[?2004l\r"]
[279.3709, "o", "\u001b[?2004h> "]
[279.371001, "o", "        return binding.process(record);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[279.371082, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[279.371136, "o", "> "]
[279.371303, "o", "    @Override\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.371564, "o", "    public void close() throws Exception {\r\n\u001b[?2004l\r"]
[279.371689, "o", "\u001b[?2004h> "]
[279.3718, "o", "        revisions.close();\r\n\u001b[?2004l\r"]
[279.371853, "o", "\u001b[?2004h> "]
[279.372099, "o", "        workers.shutdownNow();\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.372152, "o", "> "]
[279.372608, "o", "        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.372747, "o", "        ThreadBridge.clearAll();\r\n"]
[279.372822, "o", "\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.372957, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.373326, "o", "    private static final class WorkerThreadFactory implements ThreadFactory {\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.373384, "o", "> "]
[279.373769, "o", "        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[279.373883, "o", "\u001b[?2004h> "]
[279.373957, "o", "        @Override\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.374291, "o", "        public Thread newThread(Runnable runnable) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.374781, "o", "            Thread thread = new Thread(runnable);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.375269, "o", "            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.375502, "o", "            thread.setDaemon(true);\r\n\u001b[?2004l\r\u001b[?2004h"]
[279.375621, "o", "> "]
[279.375755, "o", "            return thread;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[279.375812, "o", "        }\r\n\u001b[?2004l\r"]
[279.375967, "o", "\u001b[?2004h"]
[279.376023, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[279.37607, "o", "\u001b[?2004h> "]
