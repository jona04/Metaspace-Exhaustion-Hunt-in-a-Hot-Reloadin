[202.862954, "o", "\r\n\u001b[?2004l\r"]
[202.865339, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\n\"$ROOT_DIR/bin/build\"\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/integration\" 24 >/tmp/textd-integration.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.RuntimeDigestRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-session.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.SessionReplayRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-replay.json\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/stress\" 500 >/tmp/textd-stress.log\r\n\r\necho \"suite-ok\"\r\n"]
[202.866286, "o", "\u001b[?2004h"]
[202.867039, "o", "root@dfc7e4b4db27:/workspace/textd# "]
[205.906245, "i", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\n"]
[205.9072, "o", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java"]
[205.907543, "o", "\r\n"]
[205.908288, "o", "\u001b[?2004l\r"]
[205.909938, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class TimelineLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();\r\n    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    TimelineLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));\r\n        TimelineFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    TimelineFrame current() {\r\n        TimelineFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isBalanced() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        TimelineFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(TimelineFrame::isDrained);\r\n    }\r\n}\r\n"]
[205.910207, "o", "\u001b[?2004h"]
[205.910492, "o", "root@dfc7e4b4db27:/workspace/textd# "]
[206.401987, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[206.403407, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java"]
[206.403905, "o", "\r\n"]
[206.403989, "o", "\u001b[?2004l\r"]
[206.406059, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[206.406874, "o", "\u001b[?2004hroot@dfc7e4b4db27:/workspace/textd# "]
[217.443921, "i", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\n"]
[217.444639, "o", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\r\n\u001b[?2004l\r"]
[217.446178, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\n\r\npublic final class HotReloadStressRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n\r\n    private HotReloadStressRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int cycles = args.length > 1 ? Integer.parseInt(args[1]) : 500;\r\n\r\n        try (TextDaemon daemon = new TextDaemon(pluginJar, 4)) {\r\n            for (int generation = 1; generation <= cycles; generation++) {\r\n                daemon.reload(generation);\r\n                assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE)));\r\n                assertOutput(generation, daemon.process(SAMPLE));\r\n                if (generation % 3 == 0) {\r\n                    assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE)));\r\n                }\r\n            }\r\n        }\r\n\r\n        System.out.println(\"stress-ok cycles=\" + cycles);\r\n    }\r\n\r\n    private static void assertOutputs(long generation, List<ProcessingResult> results) {\r\n        for (ProcessingResult result : results) {\r\n            assertOutput(generation, result);\r\n        }\r\n    }\r\n\r\n    private static void assertOutput(long generation, ProcessingResult result) {\r\n        String expected = OutputFormat.expectedFor(generation, SAMPLE);\r\n        if (!expected.equals(result.output())) {\r\n            throw new IllegalStateException(\"Unexpected output at generation \" + generation + \": \" + result.output());\r\n        }\r\n    }\r\n}\r\n"]
[217.446546, "o", "\u001b[?2004hroot@dfc7e4b4db27:/workspace/textd# "]
[220.952657, "i", "cat src/main/java/io/harbor/textd/cli/HotReloadIntegrationRunner.java\n"]
[220.953426, "o", "cat src/main/java/io/harbor/textd/cli/HotReloadIntegrationRunner.java\r\n\u001b[?2004l\r"]
[220.955361, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\npublic final class HotReloadIntegrationRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n\r\n    private HotReloadIntegrationRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int revision = args.length > 1 ? Integer.parseInt(args[1]) : 24;\r\n\r\n        try (TextDaemon daemon = new TextDaemon(pluginJar, 4)) {\r\n            daemon.reload(1);\r\n            List<ProcessingResult> baselineResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n            assertOutputs(1, baselineResults);\r\n\r\n            List<ProcessingResult> currentResults = baselineResults;\r\n            for (int current = 2; current <= revision; current++) {\r\n                daemon.reload(current);\r\n                currentResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n                assertOutputs(current, currentResults);\r\n            }\r\n\r\n            String baseline = baselineResults.get(0).output();\r\n            String current = currentResults.get(0).output();\r\n\r\n            System.out.println(\"{\");\r\n            System.out.println(\"  \\\"input\\\": \\\"\" + SAMPLE + \"\\\",\");\r\n            System.out.println(\"  \\\"baseline\\\": \\\"\" + baseline + \"\\\",\");\r\n            System.out.println(\"  \\\"revision\\\": \" + revision + \",\");\r\n            System.out.println(\"  \\\"current\\\": \\\"\" + current + \"\\\"\");\r\n            System.out.println(\"}\");\r\n        }\r\n    }\r\n\r\n    private static void assertOutputs(long revision, List<ProcessingResult> results) {\r\n        String expected = OutputFormat.expectedFor(revision, SAMPLE);\r\n        for (ProcessingResult result : results) {\r\n            if (!expected.equals(result.output())) {\r\n                throw new IllegalStateException(\"Unexpected output at revision \" + revision + \": \" + result.output());\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[220.955636, "o", "\u001b[?2004hroot@dfc7e4b4db27:/workspace/textd# "]
[237.379896, "i", "cat src/main/java/io/harbor/textd/cli/SessionReplayRunner.java\n"]
[237.38279, "o", "cat src/main/java/io/harbor/textd/cli/SessionReplayRunner.java"]
[237.383015, "o", "\r\n\u001b[?2004l\r"]
[237.384788, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.lang.management.ClassLoadingMXBean;\r\nimport java.lang.management.ManagementFactory;\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\nimport java.util.stream.Collectors;\r\n\r\npublic final class SessionReplayRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n    private static final ClassLoadingMXBean CLASS_LOADING = ManagementFactory.getClassLoadingMXBean();\r\n\r\n    private SessionReplayRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int revision = args.length > 1 ? Integer.parseInt(args[1]) : 24;\r\n\r\n        Session first = runSession(pluginJar, revision);\r\n        Session second = runSession(pluginJar, revision);\r\n\r\n        System.out.println(\"{\");\r\n        System.out.println(\"  \\\"first\\\": \" + first.toJson() + \",\");\r\n        System.out.println(\"  \\\"second\\\": \" + second.toJson());\r\n        System.out.println(\"}\");\r\n    }\r\n\r\n    private static Session runSession(Path pluginJar, int revision) throws Exception {\r\n        long loadedBefore = CLASS_LOADING.getLoadedClassCount();\r\n        long unloadedBefore = CLASS_LOADING.getUnloadedClassCount();\r\n\r\n        TextDaemon daemon = new TextDaemon(pluginJar, 4);\r\n        try {\r\n            daemon.reload(1);\r\n            List<ProcessingResult> firstResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n            assertOutputs(1, firstResults);\r\n\r\n            List<String> workersStart = workerThreads(firstResults);\r\n            List<ProcessingResult> finalResults = firstResults;\r\n            for (int current = 2; current <= revision; current++) {\r\n                daemon.reload(current);\r\n                finalResults = daemon.processBatch(List.of(SAMPLE, SAMPLE, SAMPLE, SAMPLE));\r\n                assertOutputs(current, finalResults);\r\n            }\r\n\r\n            List<String> workersEnd = workerThreads(finalResults);\r\n            boolean sameWorkers = workersStart.equals(workersEnd);\r\n            boolean beforeClose = daemon.isBalanced();\r\n            String first = firstResults.get(0).output();\r\n            String last = finalResults.get(0).output();\r\n\r\n            daemon.close();\r\n            drainGc();\r\n\r\n            return new Session(\r\n                first,\r\n                last,\r\n                workersStart,\r\n                workersEnd,\r\n                sameWorkers,\r\n                beforeClose,\r\n                daemon.isBalanced(),\r\n                loadedBefore,\r\n                CLASS_LOADING.getLoadedClassCount(),\r\n                unloadedBefore,\r\n                CLASS_LOADING.getUnloadedClassCount()\r\n            );\r\n        } catch (Exception exception) {\r\n            try {\r\n                daemon.close();\r\n            } catch (Exception closeException) {\r\n                exception.addSuppressed(closeException);\r\n            }\r\n            throw exception;\r\n        }\r\n    }\r\n\r\n    private static List<String> workerThreads(List<ProcessingResult> results) {\r\n        return results.stream()\r\n            .map(ProcessingResult::workerThread)\r\n            .sorted()\r\n            .collect(Collectors.toList());\r\n    }\r\n\r\n    private static void drainGc() throws InterruptedException {\r\n        for (int i = 0; i < 3; i++) {\r\n            System.gc();\r\n            Thread.sleep(50);\r\n        }\r\n    }\r\n\r\n    private static void assertOutputs(long revision, List<ProcessingResult> results) {\r\n        String expected = OutputFormat.expectedFor(revision, SAMPLE);\r\n        for (ProcessingResult result : results) {\r\n            if (!expected.equals(result.output())) {\r\n                throw new IllegalStateException(\"Unexpected output at revision \" + revision + \": \" + result.output());\r\n            }\r\n        }\r\n    }\r\n\r\n    private static String toJsonArray(List<String> values) {\r\n        return values.stream()\r\n            .map(value -> \"\\\"\" + value + \"\\\"\")\r\n            .collect(Collectors.joining(\", \", \"[\", \"]\"));\r\n    }\r\n\r\n    private static final class Session {\r\n        private final String first;\r\n        private final String last;\r\n        private final List<String> start;\r\n        private final List<String> end;\r\n        private final boolean sameWorkers;\r\n        private final boolean beforeClose;\r\n        private final boolean afterClose;\r\n        private final long loadedBeforeClose;\r\n        private final long loadedAfterClose;\r\n        private final long unloadedBeforeClose;\r\n        private final long unloadedAfterClose;\r\n\r\n        private Session(\r\n            String first,\r\n            String last,\r\n            List<String> start,\r\n            List<String> end,\r\n            boolean sameWorkers,\r\n            boolean beforeClose,\r\n            boolean afterClose,\r\n            long loadedBeforeClose,\r\n            long loadedAfterClose,\r\n            long unloadedBeforeClose,\r\n            long unloadedAfterClose\r\n        ) {\r\n            this.first = first;\r\n            this.last = last;\r\n            this.start = start;\r\n            this.end = end;\r\n            this.sameWorkers = sameWorkers;\r\n            this.beforeClose = beforeClose;\r\n            this.afterClose = afterClose;\r\n            this.loadedBeforeClose = loadedBeforeClose;\r\n            this.loadedAfterClose = loadedAfterClose;\r\n            this.unloadedBeforeClose = unloadedBeforeClose;\r\n            this.unloadedAfterClose = unloadedAfterClose;\r\n        }\r\n\r\n        private String toJson() {\r\n            return \"{\"\r\n                + \"\\\"first\\\":\\\"\" + first + \"\\\",\"\r\n                + \"\\\"last\\\":\\\"\" + last + \"\\\",\"\r\n                + \"\\\"start\\\":\" + toJsonArray(start) + \",\"\r\n                + \"\\\"end\\\":\" + toJsonArray(end) + \",\"\r\n                + \"\\\"same_workers\\\":\" + sameWorkers + \",\"\r\n                + \"\\\"before_close\\\":\" + beforeClose + \",\"\r\n                + \"\\\"after_close\\\":\" + afterClose + \",\"\r\n                + \"\\\"loaded_before_close\\\":\" + loadedBeforeClose + \",\"\r\n                + \"\\\"loaded_after_close\\\":\" + loadedAfterClose + \",\"\r\n                + \"\\\"unloaded_before_close\\\":\" + unloadedBeforeClose + \",\"\r\n                + \"\\\"unloaded_after_close\\\":\" + unloadedAfterClose\r\n                + \"}\";\r\n        }\r\n    }\r\n}\r\n"]
