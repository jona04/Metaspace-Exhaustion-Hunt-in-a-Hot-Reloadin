[192.294304, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            if (cursor != null) cursor.close(); cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            if (cursor != null) cursor.close(); cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[192.294607, "o", "\u001b[?2004hroot@58df5f9b274f:/workspace/textd# "]
[192.800512, "i", "sed -i 's/if (cursor != null) cursor.close(); // REVERTED/g' src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
