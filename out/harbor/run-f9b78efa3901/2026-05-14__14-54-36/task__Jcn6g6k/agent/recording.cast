[262.335119, "o", "\u001b[?2004h>     public void reload(long generation) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h>         revisions.install(generation);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.335286, "o", "    }\r\n\u001b[?2004l\r"]
[262.335445, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.335749, "o", "    public ProcessingResult process(String record) throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.336067, "o", "        return processBatch(List.of(record)).get(0);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.336228, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.33651, "o", "    public boolean isBalanced() {\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.336693, "o", "> "]
[262.336933, "o", "        return revisions.isBalanced();\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.337039, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.337457, "o", "    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n\u001b[?2004l\r"]
[262.33762, "o", "\u001b[?2004h> "]
[262.337901, "o", "        CountDownLatch ready = new CountDownLatch(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.340318, "o", "        CountDownLatch release = new CountDownLatch(1);\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.340398, "o", "> "]
[262.340741, "o", "        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.341327, "o", "        for (String record : records) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.341658, "o", "            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n\u001b[?2004l\r"]
[262.341899, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[262.34263, "o", "\u001b[?2004h> "]
[262.342691, "o", "        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n\u001b[?2004l\r\u001b[?2004h>             throw new IllegalStateException(\"Workers did not become ready\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.343977, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>         release.countDown();\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         List<ProcessingResult> results = new ArrayList<>(records.size());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.344346, "o", "        for (Future<ProcessingResult> future : futures) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.344404, "o", "            try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.344686, "o", "                results.add(future.get());\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.34515, "o", "            } catch (ExecutionException exception) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.345465, "o", "                Throwable cause = exception.getCause();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.345849, "o", "                if (cause instanceof Exception checked) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.346148, "o", "> "]
[262.34636, "o", "                    throw checked;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.346515, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.346908, "o", "                if (cause instanceof Error error) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.347085, "o", "                    throw error;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.347248, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.347564, "o", "                throw new RuntimeException(cause);\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.347747, "o", "> "]
[262.3478, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.348092, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>         return results;\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.348368, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[262.348495, "o", "\u001b[?2004h> "]
[262.34864, "o", "    private ProcessingResult processRecord(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.348882, "o", "        String record,\r\n\u001b[?2004l\r"]
[262.348945, "o", "\u001b[?2004h> "]
[262.349171, "o", "        CountDownLatch ready,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.349362, "o", "        CountDownLatch release\r\n\u001b[?2004l\r"]
[262.349575, "o", "\u001b[?2004h>     ) throws Exception {\r\n\u001b[?2004l\r"]
[262.349663, "o", "\u001b[?2004h> "]
[262.349834, "o", "        ready.countDown();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.350444, "o", "        if (!release.await(5, TimeUnit.SECONDS)) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.350695, "o", "            throw new IllegalStateException(\"Request release timed out\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.350929, "o", ">         }\r\n\u001b[?2004l\r"]
[262.351042, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.351357, "o", "        WorkerHandle binding = ThreadBridge.current(revisions);\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.351518, "o", "> "]
[262.351842, "o", "        return binding.process(record);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[262.352086, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.352336, "o", "    @Override\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.352551, "o", "    public void close() throws Exception {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.352792, "o", "        revisions.close();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.353046, "o", "        List<Future<?>> cleanups = new ArrayList<>();\r\n\u001b[?2004l\r"]
[262.353219, "o", "\u001b[?2004h> "]
[262.353445, "o", "        for (int i = 0; i < workerCount; i++) {\r\n\u001b[?2004l\r"]
[262.353638, "o", "\u001b[?2004h> "]
[262.35391, "o", "            cleanups.add(workers.submit(ThreadBridge::clear));\r\n\u001b[?2004l\r"]
[262.35415, "o", "\u001b[?2004h> "]
[262.354497, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.354773, "o", "        for (Future<?> cleanup : cleanups) {\r\n\u001b[?2004l\r\u001b[?2004h>             try {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.354993, "o", "                cleanup.get(1, TimeUnit.SECONDS);\r\n\u001b[?2004l\r"]
[262.355164, "o", "\u001b[?2004h> "]
[262.355398, "o", "            } catch (Exception ignored) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.355689, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[262.355854, "o", "\u001b[?2004h> "]
[262.356131, "o", "        workers.shutdownNow();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.369272, "o", "        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.369595, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.369858, "o", "    private static final class WorkerThreadFactory implements ThreadFactory {\r\n\u001b[?2004l\r"]
[262.370142, "o", "\u001b[?2004h> "]
[262.370423, "o", "        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\u001b[?2004l\r"]
[262.370747, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         @Override\r\n\u001b[?2004l\r"]
[262.370954, "o", "\u001b[?2004h> "]
[262.371212, "o", "        public Thread newThread(Runnable runnable) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[262.372551, "o", "            Thread thread = new Thread(runnable);\r\n"]
[262.373015, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[262.373116, "o", "            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());"]
[262.373391, "o", "\r\n"]
[262.373596, "o", "\u001b[?2004l\r"]
[262.374073, "o", "\u001b[?2004h"]
[262.374447, "o", ">             thread.setDaemon(true);"]
[262.374673, "o", "\r\n\u001b[?2004l\r"]
[262.374982, "o", "\u001b[?2004h"]
[262.375094, "o", ">             return thread;"]
[262.375303, "o", "\r\n\u001b[?2004l\r"]
[262.375443, "o", "\u001b[?2004h> "]
[262.375634, "o", "        }"]
[262.375699, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.376049, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.376242, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[262.37687, "o", "> EOF\r\n\u001b[?2004l\r"]
