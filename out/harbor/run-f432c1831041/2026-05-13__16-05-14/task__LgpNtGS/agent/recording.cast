[49.242272, "o", "sed -i 's/cursor = new WorkerHandle(frame);/if (cursor != null) { cursor.close(); }\\n            cursor = new WorkerHandle(frame);/' src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
