[112.903957, "i", "cat <<EOF > src/main/java/io/harbor/textd/cli/BalanceCheck.java\npackage io.harbor.textd.cli;\n\nimport io.harbor.textd.core.TextDaemon;\nimport java.nio.file.Path;\n\npublic class BalanceCheck {\n    public static void main(String[] args) throws Exception {\n        Path pluginJar = Path.of(args[0]);\n        try (TextDaemon daemon = new TextDaemon(pluginJar, 1)) {\n            for (int i = 1; i <= 5; i++) {\n                daemon.reload(i);\n                daemon.process(\"test\");\n            }\n            System.out.println(\"Is balanced: \" + daemon.isBalanced());\n            // Give it a bit of time or another process call if needed, \n            // although in this single-threaded case it should be immediate.\n            daemon.process(\"test\");\n            System.out.println(\"Is balanced after more processing: \" + daemon.isBalanced());\n        }\n    }\n}\nEOF\n"]
[112.904639, "o", "cat <<EOF > src/main/java/io/harbor/textd/cli/BalanceCheck.java\r\n\u001b[?2004l\r"]
