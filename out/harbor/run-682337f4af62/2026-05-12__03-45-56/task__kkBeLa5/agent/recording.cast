[49.515544, "i", "cat > src/main/java/io/harbor/textd/core/RouteState.java <<EOF\npackage io.harbor.textd.core;\n\nfinal class RouteState implements AutoCloseable {\n    private RouteCursor cursor;\n\n    RouteCursor cursorFor(RevisionLedger ledger) {\n        RevisionFrame frame = ledger.current();\n        if (cursor != null && !cursor.matches(frame)) {\n            cursor.close();\n            cursor = null;\n        }\n\n        if (cursor == null) {\n            cursor = new RouteCursor(frame);\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
