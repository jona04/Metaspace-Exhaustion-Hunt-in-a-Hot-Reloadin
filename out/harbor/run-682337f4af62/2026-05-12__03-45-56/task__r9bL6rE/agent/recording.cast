[141.299199, "o", "\u001b[35m\u001b[Ksrc/main/java/io/harbor/textd/core/ThreadState.java\u001b[m\u001b[K\u001b[36m\u001b[K:\u001b[m\u001b[K    private static final ThreadLocal<\u001b[01;31m\u001b[KRouteState\u001b[m\u001b[K> ROUTES = ThreadLocal.withInitial(\u001b[01;31m\u001b[KRouteState\u001b[m\u001b[K::new);\r\n\u001b[35m\u001b[Ksrc/main/java/io/harbor/textd/core/ThreadState.java\u001b[m\u001b[K\u001b[36m\u001b[K:\u001b[m\u001b[K        \u001b[01;31m\u001b[KRouteState\u001b[m\u001b[K routeState = ROUTES.get();\r\n"]
