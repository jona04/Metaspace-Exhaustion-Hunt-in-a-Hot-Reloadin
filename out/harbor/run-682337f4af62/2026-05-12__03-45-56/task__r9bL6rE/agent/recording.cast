[143.058766, "o", "package io.harbor.textd.core;\r\n\r\nfinal class RouteState implements AutoCloseable {\r\n    private RouteCursor cursor;\r\n\r\n    RouteCursor cursorFor(RevisionLedger ledger) {\r\n        RevisionFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new RouteCursor(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) { cursor.close();\r\n            cursor = new RouteCursor(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[143.05903, "o", "\u001b[?2004hroot@a8a9a2736253:/workspace/textd# "]
