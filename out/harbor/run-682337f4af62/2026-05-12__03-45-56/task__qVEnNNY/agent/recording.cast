[42.581879, "i", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\n"]
[42.582426, "o", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\r\n\u001b[?2004l\r"]
[42.583628, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\nimport java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final RevisionLedger revisions;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.revisions = new RevisionLedger(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        revisions.install(generation);\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public boolean isSteady() {\r\n        return revisions.isSteady();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        RouteCursor binding = ThreadState.current(revisions);\r\n        return binding.process(record);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        revisions.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[42.583911, "o", "\u001b[?2004hroot@664a9b7d4f73:/workspace/textd# "]
[47.516481, "i", "cat src/main/java/io/harbor/textd/core/ThreadState.java\n"]
[47.517031, "o", "cat src/main/java/io/harbor/textd/core/ThreadState.java\r\n\u001b[?2004l\r"]
[47.51825, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadState {\r\n    private static final ThreadLocal<RouteState> ROUTES = ThreadLocal.withInitial(RouteState::new);\r\n\r\n    private ThreadState() {\r\n    }\r\n\r\n    static RouteCursor current(RevisionLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        RouteState routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[47.518502, "o", "\u001b[?2004hroot@664a9b7d4f73:/workspace/textd# "]
[47.716663, "i", "cat src/main/java/io/harbor/textd/core/RevisionLedger.java\n"]
[47.717311, "o", "cat src/main/java/io/harbor/textd/core/RevisionLedger.java\r\n\u001b[?2004l\r"]
[47.7189, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class RevisionLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<RevisionFrame> current = new AtomicReference<>();\r\n    private final Queue<RevisionFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    RevisionLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        RevisionFrame next = new RevisionFrame(LoadedGeneration.load(pluginJar, revision));\r\n        RevisionFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    RevisionFrame current() {\r\n        RevisionFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isSteady() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        RevisionFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(RevisionFrame::isDrained);\r\n    }\r\n}\r\n"]
[47.719057, "o", "\u001b[?2004h"]
[47.719224, "o", "root@664a9b7d4f73:/workspace/textd# "]
[87.86573, "i", "cat src/main/java/io/harbor/textd/core/RouteState.java\n"]
[87.86628, "o", "cat src/main/java/io/harbor/textd/core/RouteState.java\r\n\u001b[?2004l\r"]
[87.867914, "o", "package io.harbor.textd.core;\r\n\r\nfinal class RouteState implements AutoCloseable {\r\n    private RouteCursor cursor;\r\n\r\n    RouteCursor cursorFor(RevisionLedger ledger) {\r\n        RevisionFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new RouteCursor(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor = new RouteCursor(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[87.868416, "o", "\u001b[?2004h"]
[87.868555, "o", "root@664a9b7d4f73:/workspace/textd# "]
[88.063215, "i", "cat src/main/java/io/harbor/textd/core/RevisionFrame.java\n"]
[88.063786, "o", "cat src/main/java/io/harbor/textd/core/RevisionFrame.java\r\n\u001b[?2004l\r"]
[88.065188, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class RevisionFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    RevisionFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    RevisionFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[88.065517, "o", "\u001b[?2004hroot@664a9b7d4f73:/workspace/textd# "]
[88.301022, "i", "cat src/main/java/io/harbor/textd/core/RouteCursor.java\n"]
[88.301579, "o", "cat src/main/java/io/harbor/textd/core/RouteCursor.java\r\n\u001b[?2004l\r"]
[88.304566, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class RouteCursor implements AutoCloseable {\r\n    private final RevisionFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    RouteCursor(RevisionFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(RevisionFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[88.304939, "o", "\u001b[?2004hroot@664a9b7d4f73:/workspace/textd# "]
[92.324967, "i", "cat <<EOF > src/main/java/io/harbor/textd/core/RouteState.java\npackage io.harbor.textd.core;\n\nfinal class RouteState implements AutoCloseable {\n    private RouteCursor cursor;\n\n    RouteCursor cursorFor(RevisionLedger ledger) {\n        RevisionFrame frame = ledger.current();\n        if (cursor == null) {\n            cursor = new RouteCursor(frame);\n            return cursor;\n        }\n\n        if (!cursor.matches(frame)) {\n            cursor.close();\n            cursor = new RouteCursor(frame);\n            return cursor;\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
