[123.261656, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[123.263847, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[123.266496, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor.close();\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[123.266829, "o", "\u001b[?2004hroot@df532665a8df:/workspace/textd# "]
