[43.485574, "o", "sed -i 's/cursor = new WorkerHandle(frame);/cursor.close(); cursor = new WorkerHandle(frame);/' src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[43.539667, "o", "\u001b[?2004hroot@e4a7dcc4d1be:/workspace/textd# "]
