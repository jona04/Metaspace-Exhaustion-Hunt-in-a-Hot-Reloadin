[40.956781, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[40.957472, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[40.9727, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor.close();\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[40.973136, "o", "\u001b[?2004hroot@fb88dd3b7517:/workspace/textd# "]
[43.796072, "i", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\n"]
[43.796659, "o", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\r\n\u001b[?2004l\r"]
[43.798025, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadBridge {\r\n    private static final ThreadLocal<ThreadCache> ROUTES = ThreadLocal.withInitial(ThreadCache::new);\r\n\r\n    private ThreadBridge() {\r\n    }\r\n\r\n    static WorkerHandle current(TimelineLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        ThreadCache routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[43.798312, "o", "\u001b[?2004hroot@fb88dd3b7517:/workspace/textd# "]
