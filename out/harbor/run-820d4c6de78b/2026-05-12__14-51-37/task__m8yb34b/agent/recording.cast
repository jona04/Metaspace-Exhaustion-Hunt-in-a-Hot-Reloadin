[40.917076, "o", "sed -i 's/if (!cursor.matches(frame)) {/if (!cursor.matches(frame)) {\\n            cursor.close();/' src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
