[77.669292, "o", "\u001b[?2004l\r"]
[77.669421, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\nimport java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final ExecutorService reloadExecutor;\r\n    private final TimelineLedger revisions;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.revisions = new TimelineLedger(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.reloadExecutor = Executors.newSingleThreadExecutor(r -> {\r\n            Thread t = new Thread(r, \"textd-reload\");\r\n            t.setDaemon(true);\r\n            return t;\r\n        });\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        revisions.install(generation);\r\n        reloadExecutor.submit(this::primeReloadBinding).get();\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public boolean isBalanced() {\r\n        return revisions.isBalanced();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        WorkerHandle binding = ThreadBridge.current(revisions);\r\n"]
[77.669507, "o", "        return binding.process(record);\r\n    }\r\n\r\n    private void primeReloadBinding() {\r\n        ThreadBridge.current(revisions);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        revisions.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[77.670623, "o", "\u001b[?2004hroot@86a295386135:/workspace/textd# "]
[77.982876, "i", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\n"]
[77.984867, "o", "cat src/main/java/io/harbor/textd/core/WorkerHandle.java\r\n\u001b[?2004l\r"]
[77.986891, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class WorkerHandle implements AutoCloseable {\r\n    private final TimelineFrame frame;\r\n    private final long revision;\r\n    private final TextProcessor processor;\r\n\r\n    WorkerHandle(TimelineFrame frame) {\r\n        this.frame = frame.pin();\r\n        this.revision = frame.revision();\r\n        this.processor = frame.module().processorFor(revision);\r\n    }\r\n\r\n    boolean matches(TimelineFrame frame) {\r\n        return revision == frame.revision();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(revision, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        frame.unpin();\r\n    }\r\n}\r\n"]
[77.987742, "o", "\u001b[?2004hroot@86a295386135:/workspace/textd# "]
[78.304951, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[78.30651, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[78.310861, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[78.313708, "o", "\u001b[?2004hroot@86a295386135:/workspace/textd# "]
[82.554382, "i", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java\n"]
[82.556126, "o", "cat src/main/java/io/harbor/textd/core/ThreadBridge.java"]
[82.557145, "o", "\r\n\u001b[?2004l\r"]
[82.559729, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadBridge {\r\n    private static final ThreadLocal<ThreadCache> ROUTES = ThreadLocal.withInitial(ThreadCache::new);\r\n\r\n    private ThreadBridge() {\r\n    }\r\n\r\n    static WorkerHandle current(TimelineLedger ledger) {\r\n        return ROUTES.get().cursorFor(ledger);\r\n    }\r\n\r\n    static void clear() {\r\n        ThreadCache routeState = ROUTES.get();\r\n        routeState.close();\r\n        ROUTES.remove();\r\n    }\r\n}\r\n"]
[82.561039, "o", "\u001b[?2004h"]
[82.561556, "o", "root@86a295386135:/workspace/textd# "]
[82.899937, "i", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\n"]
[82.901553, "o", "cat src/main/java/io/harbor/textd/core/TimelineFrame.java\r\n\u001b[?2004l\r"]
[82.903462, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class TimelineFrame {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger pins = new AtomicInteger(1);\r\n    private final AtomicBoolean cooled = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    TimelineFrame(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    TimelineFrame pin() {\r\n        while (true) {\r\n            int current = pins.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Revision \" + revision() + \" is already closed\");\r\n            }\r\n            if (pins.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long revision() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void cool() {\r\n        if (cooled.compareAndSet(false, true)) {\r\n            unpin();\r\n        }\r\n    }\r\n\r\n    void unpin() {\r\n        int remaining = pins.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Pin count underflow for revision \" + revision());\r\n        }\r\n        if (remaining == 0 && cooled.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isDrained() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close revision \" + revision(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[82.903878, "o", "\u001b[?2004hroot@86a295386135:/workspace/textd# "]
[83.214867, "i", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java\n"]
[83.218033, "o", "cat src/main/java/io/harbor/textd/core/TimelineLedger.java"]
[83.218347, "o", "\r\n\u001b[?2004l\r"]
[83.225035, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class TimelineLedger {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<TimelineFrame> current = new AtomicReference<>();\r\n    private final Queue<TimelineFrame> shadow = new ConcurrentLinkedQueue<>();\r\n\r\n    TimelineLedger(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void install(long revision) throws Exception {\r\n        TimelineFrame next = new TimelineFrame(LoadedGeneration.load(pluginJar, revision));\r\n        TimelineFrame previous = current.getAndSet(next);\r\n        if (previous != null) {\r\n            shadow.add(previous);\r\n            previous.cool();\r\n            pruneShadow();\r\n        }\r\n    }\r\n\r\n    TimelineFrame current() {\r\n        TimelineFrame frame = current.get();\r\n        if (frame == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return frame;\r\n    }\r\n\r\n    boolean isBalanced() {\r\n        pruneShadow();\r\n        return shadow.isEmpty();\r\n    }\r\n\r\n    void close() {\r\n        TimelineFrame frame = current.getAndSet(null);\r\n        if (frame != null) {\r\n            shadow.add(frame);\r\n            frame.cool();\r\n        }\r\n        pruneShadow();\r\n    }\r\n\r\n    private void pruneShadow() {\r\n        shadow.removeIf(TimelineFrame::isDrained);\r\n    }\r\n}\r\n"]
[83.225897, "o", "\u001b[?2004hroot@86a295386135:/workspace/textd# "]
[89.870182, "i", "cat <<EOF > src/main/java/io/harbor/textd/core/ThreadCache.java\npackage io.harbor.textd.core;\n\nfinal class ThreadCache implements AutoCloseable {\n    private WorkerHandle cursor;\n\n    WorkerHandle cursorFor(TimelineLedger ledger) {\n        TimelineFrame frame = ledger.current();\n        if (cursor == null) {\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        if (!cursor.matches(frame)) {\n            cursor.close();\n            cursor = new WorkerHandle(frame);\n            return cursor;\n        }\n\n        return cursor;\n    }\n\n    @Override\n    public void close() {\n        if (cursor != null) {\n            cursor.close();\n            cursor = null;\n        }\n    }\n}\nEOF\n"]
