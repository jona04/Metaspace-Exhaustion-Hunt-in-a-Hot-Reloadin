[59.558675, "o", "java.util.concurrent.ExecutionException: java.lang.NullPointerException: Cannot invoke \"io.harbor.textd.core.WorkerHandle.close()\" because \"this.cursor\" is null\r\n\tat java.base/java.util.concurrent.FutureTask.report(FutureTask.java:122)\r\n\tat java.base/java.util.concurrent.FutureTask.get(FutureTask.java:191)\r\n\tat io.harbor.textd.core.TextDaemon.reload(TextDaemon.java:34)\r\n\tat io.harbor.textd.cli.HotReloadStressRunner.main(HotReloadStressRunner.java:22)\r\nCaused by: java.lang.NullPointerException: Cannot invoke \"io.harbor.textd.core.WorkerHandle.close()\" because \"this.cursor\" is null\r\n\tat io.harbor.textd.core.ThreadCache.cursorFor(ThreadCache.java:9)\r\n\tat io.harbor.textd.core.ThreadBridge.current(ThreadBridge.java:10)\r\n\tat io.harbor.textd.core.TextDaemon.primeReloadBinding(TextDaemon.java:91)\r\n\tat java.base/java.util.concurrent.Executors$RunnableAdapter.call(Executors.java:539)\r\n\tat java.base/java.util.concurrent.FutureTask.run(FutureTask.java:264)\r\n"]
