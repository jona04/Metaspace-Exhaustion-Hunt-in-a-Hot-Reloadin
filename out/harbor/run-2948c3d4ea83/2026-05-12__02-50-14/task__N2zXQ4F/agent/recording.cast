[17.813821, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\nif [[ \"${TEXTD_SKIP_BUILD:-0}\" != \"1\" ]]; then\r\n  \"$ROOT_DIR/bin/build\"\r\nfi\r\n\r\njava -XX:MaxMetaspaceSize=64m -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.HotReloadStressRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  \"${1:-500}\"\r\n"]
[17.814047, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[20.620384, "i", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\n"]
[20.620973, "o", "cat src/main/java/io/harbor/textd/cli/HotReloadStressRunner.java\r\n\u001b[?2004l\r"]
[20.622221, "o", "package io.harbor.textd.cli;\r\n\r\nimport io.harbor.textd.core.OutputFormat;\r\nimport io.harbor.textd.core.ProcessingResult;\r\nimport io.harbor.textd.core.TextDaemon;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.List;\r\n\r\npublic final class HotReloadStressRunner {\r\n    private static final String SAMPLE = \"alpha beta gamma\";\r\n\r\n    private HotReloadStressRunner() {\r\n    }\r\n\r\n    public static void main(String[] args) throws Exception {\r\n        Path pluginJar = Path.of(args[0]);\r\n        int cycles = args.length > 1 ? Integer.parseInt(args[1]) : 500;\r\n\r\n        try (TextDaemon daemon = new TextDaemon(pluginJar, 2)) {\r\n            for (int generation = 1; generation <= cycles; generation++) {\r\n                daemon.reload(generation);\r\n                assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE)));\r\n                assertOutput(generation, daemon.process(SAMPLE));\r\n                if (generation % 3 == 0) {\r\n                    assertOutputs(generation, daemon.processBatch(List.of(SAMPLE, SAMPLE)));\r\n                }\r\n            }\r\n        }\r\n\r\n        System.out.println(\"stress-ok cycles=\" + cycles);\r\n    }\r\n\r\n    private static void assertOutputs(long generation, List<ProcessingResult> results) {\r\n        for (ProcessingResult result : results) {\r\n            assertOutput(generation, result);\r\n        }\r\n    }\r\n\r\n    private static void assertOutput(long generation, ProcessingResult result) {\r\n        String expected = OutputFormat.expectedFor(generation, SAMPLE);\r\n        if (!expected.equals(result.output())) {\r\n            throw new IllegalStateException(\"Unexpected output at generation \" + generation + \": \" + result.output());\r\n        }\r\n    }\r\n}\r\n"]
[20.622432, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[23.272443, "i", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\n"]
[23.273086, "o", "cat src/main/java/io/harbor/textd/core/TextDaemon.java\r\n\u001b[?2004l\r"]
[23.27483, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.ArrayList;\r\nimport java.util.List;\r\n"]
[23.275395, "o", "import java.util.concurrent.CountDownLatch;\r\nimport java.util.concurrent.ExecutionException;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\nimport java.util.concurrent.Future;\r\nimport java.util.concurrent.ThreadFactory;\r\nimport java.util.concurrent.TimeUnit;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\npublic final class TextDaemon implements AutoCloseable {\r\n    private final ExecutorService workers;\r\n    private final GenerationRegistry generations;\r\n    private final int workerCount;\r\n\r\n    public TextDaemon(Path pluginJar, int workerCount) {\r\n        this.generations = new GenerationRegistry(pluginJar);\r\n        this.workers = Executors.newFixedThreadPool(workerCount, new WorkerThreadFactory());\r\n        this.workerCount = workerCount;\r\n    }\r\n\r\n    public void reload(long generation) throws Exception {\r\n        generations.activate(generation);\r\n    }\r\n\r\n    public ProcessingResult process(String record) throws Exception {\r\n        return processBatch(List.of(record)).get(0);\r\n    }\r\n\r\n    public int pendingRetirements() {\r\n        return generations.pendingRetirements();\r\n    }\r\n\r\n    public List<ProcessingResult> processBatch(List<String> records) throws Exception {\r\n        CountDownLatch ready = new CountDownLatch(records.size());\r\n        CountDownLatch release = new CountDownLatch(1);\r\n        List<Future<ProcessingResult>> futures = new ArrayList<>();\r\n        for (String record : records) {\r\n            futures.add(workers.submit(() -> processRecord(record, ready, release)));\r\n        }\r\n\r\n        if (!ready.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Workers did not become ready\");\r\n        }\r\n        release.countDown();\r\n\r\n        List<ProcessingResult> results = new ArrayList<>(records.size());\r\n        for (Future<ProcessingResult> future : futures) {\r\n            try {\r\n                results.add(future.get());\r\n            } catch (ExecutionException exception) {\r\n                Throwable cause = exception.getCause();\r\n                if (cause instanceof Exception checked) {\r\n                    throw checked;\r\n                }\r\n                if (cause instanceof Error error) {\r\n                    throw error;\r\n                }\r\n                throw new RuntimeException(cause);\r\n            }\r\n        }\r\n        return results;\r\n    }\r\n\r\n    private ProcessingResult processRecord(\r\n        String record,\r\n        CountDownLatch ready,\r\n        CountDownLatch release\r\n    ) throws Exception {\r\n        ready.countDown();\r\n        if (!release.await(5, TimeUnit.SECONDS)) {\r\n            throw new IllegalStateException(\"Request release timed out\");\r\n        }\r\n\r\n        DispatchBinding binding = WorkerBindings.current(generations);\r\n        return binding.process(record);\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        generations.close();\r\n        workers.shutdownNow();\r\n        workers.awaitTermination(5, TimeUnit.SECONDS);\r\n    }\r\n\r\n    private static final class WorkerThreadFactory implements ThreadFactory {\r\n        private final AtomicInteger sequence = new AtomicInteger(1);\r\n\r\n        @Override\r\n        public Thread newThread(Runnable runnable) {\r\n            Thread thread = new Thread(runnable);\r\n            thread.setName(\"textd-worker-\" + sequence.getAndIncrement());\r\n            thread.setDaemon(true);\r\n            return thread;\r\n        }\r\n    }\r\n}\r\n"]
[23.27565, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[25.66667, "i", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\n"]
[25.667659, "o", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
[25.668673, "o", "package io.harbor.textd.core;\r\n\r\nfinal class WorkerBindings {\r\n    private static final ThreadLocal<DispatchBinding> ACTIVE = new ThreadLocal<>();\r\n\r\n    private WorkerBindings() {\r\n    }\r\n\r\n    static DispatchBinding current(GenerationRegistry registry) {\r\n        GenerationLease activeLease = registry.active();\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding == null) {\r\n            DispatchBinding created = new DispatchBinding(activeLease);\r\n            ACTIVE.set(created);\r\n            return created;\r\n        }\r\n\r\n        if (!binding.matches(activeLease)) {\r\n            DispatchBinding replacement = new DispatchBinding(activeLease);\r\n            ACTIVE.set(replacement);\r\n            return replacement;\r\n        }\r\n\r\n        return binding;\r\n    }\r\n\r\n    static void releaseCurrent() {\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding != null) {\r\n            binding.close();\r\n            ACTIVE.remove();\r\n        }\r\n    }\r\n}\r\n"]
[25.668992, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[25.859801, "i", "cat src/main/java/io/harbor/textd/core/GenerationRegistry.java\n"]
[25.860409, "o", "cat src/main/java/io/harbor/textd/core/GenerationRegistry.java\r\n\u001b[?2004l\r"]
[25.861717, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class GenerationRegistry {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<GenerationLease> active = new AtomicReference<>();\r\n    private final Queue<GenerationLease> retired = new ConcurrentLinkedQueue<>();\r\n\r\n    GenerationRegistry(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void activate(long generation) throws Exception {\r\n        GenerationLease next = new GenerationLease(LoadedGeneration.load(pluginJar, generation));\r\n        GenerationLease previous = active.getAndSet(next);\r\n        if (previous != null) {\r\n            retired.add(previous);\r\n            previous.retire();\r\n            sweepRetired();\r\n        }\r\n    }\r\n\r\n    GenerationLease active() {\r\n        GenerationLease lease = active.get();\r\n        if (lease == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return lease;\r\n    }\r\n\r\n    int pendingRetirements() {\r\n        sweepRetired();\r\n        return retired.size();\r\n    }\r\n\r\n    void close() {\r\n        GenerationLease current = active.getAndSet(null);\r\n        if (current != null) {\r\n            retired.add(current);\r\n            current.retire();\r\n        }\r\n        sweepRetired();\r\n    }\r\n\r\n    private void sweepRetired() {\r\n        retired.removeIf(GenerationLease::isClosed);\r\n    }\r\n}\r\n"]
[25.862018, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[29.416493, "i", "cat src/main/java/io/harbor/textd/core/DispatchBinding.java\n"]
[29.418203, "o", "cat src/main/java/io/harbor/textd/core/DispatchBinding.java"]
[29.418934, "o", "\r\n\u001b[?2004l\r"]
[29.421189, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class DispatchBinding implements AutoCloseable {\r\n    private final GenerationLease lease;\r\n    private final long generation;\r\n    private final TextProcessor processor;\r\n\r\n    DispatchBinding(GenerationLease lease) {\r\n        this.lease = lease.retain();\r\n        this.generation = lease.generation();\r\n        this.processor = lease.module().processorFor(generation);\r\n    }\r\n\r\n    boolean matches(GenerationLease lease) {\r\n        return generation == lease.generation();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(generation, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        lease.release();\r\n    }\r\n}\r\n"]
[29.421365, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[29.640469, "i", "cat src/main/java/io/harbor/textd/core/GenerationLease.java\n"]
[29.641314, "o", "cat src/main/java/io/harbor/textd/core/GenerationLease.java\r\n\u001b[?2004l\r"]
[29.642613, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class GenerationLease {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger references = new AtomicInteger(1);\r\n    private final AtomicBoolean retired = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    GenerationLease(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    GenerationLease retain() {\r\n        while (true) {\r\n            int current = references.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Generation \" + generation() + \" is already closed\");\r\n            }\r\n            if (references.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long generation() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void retire() {\r\n        if (retired.compareAndSet(false, true)) {\r\n            release();\r\n        }\r\n    }\r\n\r\n    void release() {\r\n        int remaining = references.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Reference count underflow for generation \" + generation());\r\n        }\r\n        if (remaining == 0 && retired.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isClosed() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close generation \" + generation(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[29.642893, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[29.822642, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[29.823735, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n\u001b[?2004l\r"]
[29.824657, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[29.82503, "o", "\u001b[?2004hroot@84ae2dbe9a68:/workspace/textd# "]
[33.499141, "i", "sed -i 's/ACTIVE.set(replacement);/binding.close();\\n            ACTIVE.set(replacement);/' src/main/java/io/harbor/textd/core/WorkerBindings.java\n"]
[33.500067, "o", "sed -i 's/ACTIVE.set(replacement);/binding.close();\\n            ACTIVE.set(replacement);/' src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
