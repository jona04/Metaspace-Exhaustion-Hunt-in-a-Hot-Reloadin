[16.842082, "o", "package io.harbor.textd.core;\r\n\r\nfinal class WorkerBindings {\r\n    private static final ThreadLocal<DispatchBinding> ACTIVE = new ThreadLocal<>();\r\n\r\n    private WorkerBindings() {\r\n    }\r\n\r\n    static DispatchBinding current(GenerationRegistry registry) {\r\n        GenerationLease activeLease = registry.active();\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding == null) {\r\n            DispatchBinding created = new DispatchBinding(activeLease);\r\n            ACTIVE.set(created);\r\n            return created;\r\n        }\r\n\r\n        if (!binding.matches(activeLease)) {\r\n            DispatchBinding replacement = new DispatchBinding(activeLease);\r\n            ACTIVE.set(replacement);\r\n            return replacement;\r\n        }\r\n\r\n        return binding;\r\n    }\r\n\r\n    static void releaseCurrent() {\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding != null) {\r\n            binding.close();\r\n            ACTIVE.remove();\r\n        }\r\n    }\r\n}\r\n"]
[16.842429, "o", "\u001b[?2004hroot@45093db30f97:/workspace/textd# "]
[17.005986, "i", "cat src/main/java/io/harbor/textd/core/DispatchBinding.java\n"]
[17.006557, "o", "cat src/main/java/io/harbor/textd/core/DispatchBinding.java\r\n\u001b[?2004l\r"]
[17.008902, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.TextProcessor;\r\n\r\nfinal class DispatchBinding implements AutoCloseable {\r\n    private final GenerationLease lease;\r\n    private final long generation;\r\n    private final TextProcessor processor;\r\n\r\n    DispatchBinding(GenerationLease lease) {\r\n        this.lease = lease.retain();\r\n        this.generation = lease.generation();\r\n        this.processor = lease.module().processorFor(generation);\r\n    }\r\n\r\n    boolean matches(GenerationLease lease) {\r\n        return generation == lease.generation();\r\n    }\r\n\r\n    ProcessingResult process(String record) {\r\n        String output = processor.process(record);\r\n        return new ProcessingResult(generation, output, Thread.currentThread().getName());\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        lease.release();\r\n    }\r\n}\r\n\u001b[?2004hroot@45093db30f97:/workspace/textd# "]
