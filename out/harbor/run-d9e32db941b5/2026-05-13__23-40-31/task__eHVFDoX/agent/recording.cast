[3.536677, "o", "\u001b[0m\u001b[01;34mbin\u001b[0m  \u001b[01;34mbuild\u001b[0m  \u001b[01;34mplugin-src\u001b[0m  \u001b[01;34msrc\u001b[0m\r\n\r\n./bin:\r\n\u001b[01;32mbuild\u001b[0m  \u001b[01;32mintegration\u001b[0m  \u001b[01;32mrun-suite\u001b[0m  \u001b[01;32mstress\u001b[0m\r\n\r\n./build:\r\n\u001b[01;34mmain-classes\u001b[0m  \u001b[01;34mplugin-classes\u001b[0m  \u001b[01;34mplugins\u001b[0m\r\n\r\n./build/main-classes:\r\n\r\n./build/plugin-classes:\r\n\r\n./build/plugins:\r\n\r\n./plugin-src:\r\n\u001b[01;34mio\u001b[0m\r\n\r\n./plugin-src/io:\r\n\u001b[01;34mharbor\u001b[0m\r\n\r\n./plugin-src/io/harbor:\r\n\u001b[01;34mtextd\u001b[0m\r\n\r\n./plugin-src/io/harbor/textd:\r\n\u001b[01;34mcustomer\u001b[0m\r\n\r\n./plugin-src/io/harbor/textd/customer:\r\nCustomerPluginFactory.java  CustomerPluginModule.java  PipelineProcessor.java  PipelineStages.java\r\n\r\n./src:\r\n\u001b[01;34mmain\u001b[0m\r\n\r\n./src/main:\r\n\u001b[01;34mjava\u001b[0m\r\n"]
