[166.191523, "o", "cat bin/integration\r\n\u001b[?2004l\r"]
[166.192911, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\nif [[ \"${TEXTD_SKIP_BUILD:-0}\" != \"1\" ]]; then\r\n  \"$ROOT_DIR/bin/build\"\r\nfi\r\n\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.HotReloadIntegrationRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  \"${1:-12}\"\r\n"]
[166.193158, "o", "\u001b[?2004hroot@5f58f2c03018:/workspace/textd# "]
[166.289303, "i", "cat bin/run-suite\n"]
[166.28964, "o", "cat bin/run-suite\r\n\u001b[?2004l\r"]
[166.290722, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\n\"$ROOT_DIR/bin/build\"\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/integration\" 24 >/tmp/textd-integration.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.RuntimeDigestRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-session.json\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.SessionReplayRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  24 >/tmp/textd-replay.json\r\nTEXTD_SKIP_BUILD=1 \"$ROOT_DIR/bin/stress\" 500 >/tmp/textd-stress.log\r\n\r\necho \"suite-ok\"\r\n"]
[166.290949, "o", "\u001b[?2004hroot@5f58f2c03018:/workspace/textd# "]
[168.968968, "i", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\n"]
[168.969597, "o", "cat src/main/java/io/harbor/textd/core/ThreadCache.java\r\n\u001b[?2004l\r"]
[168.97075, "o", "package io.harbor.textd.core;\r\n\r\nfinal class ThreadCache implements AutoCloseable {\r\n    private WorkerHandle cursor;\r\n\r\n    WorkerHandle cursorFor(TimelineLedger ledger) {\r\n        TimelineFrame frame = ledger.current();\r\n        if (cursor == null) {\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        if (!cursor.matches(frame)) {\r\n            cursor.close();\r\n            cursor = new WorkerHandle(frame);\r\n            return cursor;\r\n        }\r\n\r\n        return cursor;\r\n    }\r\n\r\n    @Override\r\n    public void close() {\r\n        if (cursor != null) {\r\n            cursor.close();\r\n            cursor = null;\r\n        }\r\n    }\r\n}\r\n"]
[168.970938, "o", "\u001b[?2004hroot@5f58f2c03018:/workspace/textd# "]
[169.103822, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[169.10443, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n\u001b[?2004l\r"]
[169.105763, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\nimport java.util.concurrent.ConcurrentHashMap;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n    private static final ConcurrentHashMap<Long, LoadedGeneration> LIVE = new ConcurrentHashMap<>();\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        LoadedGeneration loaded = new LoadedGeneration(generation, classLoader, factory.open());\r\n        LIVE.put(generation, loaded);\r\n        return loaded;\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        try {\r\n            module.close();\r\n            classLoader.close();\r\n        } finally {\r\n            LIVE.remove(generation);\r\n        }\r\n    }\r\n}\r\n"]
[169.106048, "o", "\u001b[?2004hroot@5f58f2c03018:/workspace/textd# "]
