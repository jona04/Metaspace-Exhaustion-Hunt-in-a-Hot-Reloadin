[36.775197, "o", "sed -i 's/ACTIVE.set(replacement);/if (binding != null) { binding.close(); } ACTIVE.set(replacement);/' src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
