[471.286426, "o", "sed -i 's/ACTIVE.set(replacement);/binding.close(); ACTIVE.set(replacement);/' src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
[471.312104, "o", "\u001b[?2004hroot@4b17642b2f73:/workspace/textd# "]
[471.420753, "i", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\n"]
[471.421229, "o", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
[471.437431, "o", "package io.harbor.textd.core;\r\n\r\nfinal class WorkerBindings {\r\n    private static final ThreadLocal<DispatchBinding> ACTIVE = new ThreadLocal<>();\r\n\r\n    private WorkerBindings() {\r\n    }\r\n\r\n    static DispatchBinding current(GenerationRegistry registry) {\r\n        GenerationLease activeLease = registry.active();\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding == null) {\r\n            DispatchBinding created = new DispatchBinding(activeLease);\r\n            ACTIVE.set(created);\r\n            return created;\r\n        }\r\n\r\n        if (!binding.matches(activeLease)) {\r\n            DispatchBinding replacement = new DispatchBinding(activeLease);\r\n            binding.close(); ACTIVE.set(replacement);\r\n            return replacement;\r\n        }\r\n\r\n        return binding;\r\n    }\r\n\r\n    static void releaseCurrent() {\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding != null) {\r\n            binding.close();\r\n            ACTIVE.remove();\r\n        }\r\n    }\r\n}\r\n"]
