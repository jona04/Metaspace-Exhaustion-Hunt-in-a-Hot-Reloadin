[26.597491, "o", "\r\n\u001b[?2004l\r"]
[26.600553, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[26.602053, "o", "\u001b[?2004hroot@4decfb56fa98:/workspace/textd# "]
[26.805342, "i", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\n"]
[26.807059, "o", "cat src/main/java/io/harbor/textd/core/WorkerBindings.java\r\n\u001b[?2004l\r"]
[26.810239, "o", "package io.harbor.textd.core;\r\n\r\nfinal class WorkerBindings {\r\n    private static final ThreadLocal<DispatchBinding> ACTIVE = new ThreadLocal<>();\r\n\r\n    private WorkerBindings() {\r\n    }\r\n\r\n    static DispatchBinding current(GenerationRegistry registry) {\r\n        GenerationLease activeLease = registry.active();\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding == null) {\r\n            DispatchBinding created = new DispatchBinding(activeLease);\r\n            ACTIVE.set(created);\r\n            return created;\r\n        }\r\n\r\n        if (!binding.matches(activeLease)) {\r\n            DispatchBinding replacement = new DispatchBinding(activeLease);\r\n            ACTIVE.set(replacement);\r\n            return replacement;\r\n        }\r\n\r\n        return binding;\r\n    }\r\n\r\n    static void releaseCurrent() {\r\n        DispatchBinding binding = ACTIVE.get();\r\n        if (binding != null) {\r\n            binding.close();\r\n            ACTIVE.remove();\r\n        }\r\n    }\r\n}\r\n"]
