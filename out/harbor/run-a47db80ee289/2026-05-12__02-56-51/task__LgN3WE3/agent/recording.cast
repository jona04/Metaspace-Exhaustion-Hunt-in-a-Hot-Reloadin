[45.87084, "o", "Exception in thread \"main\" java.lang.NoClassDefFoundError: Could not initialize class io.harbor.textd.customer.PipelineStages\r\n\tat io.harbor.textd.customer.PipelineProcessor.process(PipelineProcessor.java:22)\r\n\tat io.harbor.textd.core.DispatchBinding.process(DispatchBinding.java:21)\r\n\tat io.harbor.textd.core.TextDaemon.processRecord(TextDaemon.java:80)\r\n\tat io.harbor.textd.core.TextDaemon.lambda$processBatch$0(TextDaemon.java:43)\r\n\tat java.base/java.util.concurrent.FutureTask.run(FutureTask.java:264)\r\n\tat java.base/java.util.concurrent.ThreadPoolExecutor.runWorker(ThreadPoolExecutor.java:1136)\r\n\tat java.base/java.util.concurrent.ThreadPoolExecutor$Worker.run(ThreadPoolExecutor.java:635)\r\n\tat java.base/java.lang.Thread.run(Thread.java:840)\r\nCaused by: java.lang.ExceptionInInitializerError: Exception java.lang.OutOfMemoryError: Metaspace [in thread \"textd-worker-2\"]\r\n\tat io.harbor.textd.customer.PipelineStages.<clinit>(PipelineStages.java:10)\r\n\tat io.harbor.textd.customer.PipelineProcessor.process(PipelineProcessor.java:22)\r\n\tat io.harbor.textd.core.DispatchBinding.process(DispatchBinding.java:21)\r\n\tat io.harbor.textd.core.TextDaemon.processRecord(TextDaemon.java:80)\r\n\tat io.harbor.textd.core.TextDaemon.lambda$processBatch$0(TextDaemon.java:43)\r\n\tat io.harbor.textd.core.TextDaemon$$Lambda$1/0x00007b1791001c58.call(Unknown Source)\r\n\t... 4 more\r\n"]
