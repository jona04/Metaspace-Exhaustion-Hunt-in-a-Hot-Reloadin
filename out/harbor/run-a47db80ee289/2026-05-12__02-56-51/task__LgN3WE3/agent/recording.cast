[54.302234, "o", "cat src/main/java/io/harbor/textd/core/GenerationRegistry.java\r\n\u001b[?2004l\r"]
[54.303527, "o", "package io.harbor.textd.core;\r\n\r\nimport java.nio.file.Path;\r\nimport java.util.Queue;\r\nimport java.util.concurrent.ConcurrentLinkedQueue;\r\nimport java.util.concurrent.atomic.AtomicReference;\r\n\r\nfinal class GenerationRegistry {\r\n    private final Path pluginJar;\r\n    private final AtomicReference<GenerationLease> active = new AtomicReference<>();\r\n    private final Queue<GenerationLease> retired = new ConcurrentLinkedQueue<>();\r\n\r\n    GenerationRegistry(Path pluginJar) {\r\n        this.pluginJar = pluginJar;\r\n    }\r\n\r\n    void activate(long generation) throws Exception {\r\n        GenerationLease next = new GenerationLease(LoadedGeneration.load(pluginJar, generation));\r\n        GenerationLease previous = active.getAndSet(next);\r\n        if (previous != null) {\r\n            retired.add(previous);\r\n            previous.retire();\r\n            sweepRetired();\r\n        }\r\n    }\r\n\r\n    GenerationLease active() {\r\n        GenerationLease lease = active.get();\r\n        if (lease == null) {\r\n            throw new IllegalStateException(\"No plugin generation is loaded\");\r\n        }\r\n        return lease;\r\n    }\r\n\r\n    int pendingRetirements() {\r\n        sweepRetired();\r\n        return retired.size();\r\n    }\r\n\r\n    void close() {\r\n        GenerationLease current = active.getAndSet(null);\r\n        if (current != null) {\r\n            retired.add(current);\r\n            current.retire();\r\n        }\r\n        sweepRetired();\r\n    }\r\n\r\n    private void sweepRetired() {\r\n        retired.removeIf(GenerationLease::isClosed);\r\n    }\r\n}\r\n"]
[54.303822, "o", "\u001b[?2004hroot@813cbecd3a5c:/workspace/textd# "]
[54.486959, "i", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\n"]
[54.487708, "o", "cat src/main/java/io/harbor/textd/core/LoadedGeneration.java\r\n\u001b[?2004l\r"]
[54.490231, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\nimport io.harbor.textd.api.PluginModuleFactory;\r\n\r\nimport java.net.URL;\r\nimport java.net.URLClassLoader;\r\nimport java.nio.file.Path;\r\n\r\nfinal class LoadedGeneration implements AutoCloseable {\r\n    private static final String FACTORY_CLASS = \"io.harbor.textd.customer.CustomerPluginFactory\";\r\n\r\n    private final long generation;\r\n    private final URLClassLoader classLoader;\r\n    private final PluginModule module;\r\n\r\n    private LoadedGeneration(long generation, URLClassLoader classLoader, PluginModule module) {\r\n        this.generation = generation;\r\n        this.classLoader = classLoader;\r\n        this.module = module;\r\n    }\r\n\r\n    static LoadedGeneration load(Path pluginJar, long generation) throws Exception {\r\n        URLClassLoader classLoader = new URLClassLoader(new URL[] {pluginJar.toUri().toURL()}, PluginModuleFactory.class.getClassLoader());\r\n        Class<?> factoryType = classLoader.loadClass(FACTORY_CLASS);\r\n        PluginModuleFactory factory = (PluginModuleFactory) factoryType.getDeclaredConstructor().newInstance();\r\n        return new LoadedGeneration(generation, classLoader, factory.open());\r\n    }\r\n\r\n    long generation() {\r\n        return generation;\r\n    }\r\n\r\n    PluginModule module() {\r\n        return module;\r\n    }\r\n\r\n    @Override\r\n    public void close() throws Exception {\r\n        module.close();\r\n        classLoader.close();\r\n    }\r\n}\r\n"]
[54.490793, "o", "\u001b[?2004hroot@813cbecd3a5c:/workspace/textd# "]
[54.641086, "i", "cat src/main/java/io/harbor/textd/core/GenerationLease.java\n"]
[54.641645, "o", "cat src/main/java/io/harbor/textd/core/GenerationLease.java\r\n\u001b[?2004l\r"]
[54.643035, "o", "package io.harbor.textd.core;\r\n\r\nimport io.harbor.textd.api.PluginModule;\r\n\r\nimport java.util.concurrent.atomic.AtomicBoolean;\r\nimport java.util.concurrent.atomic.AtomicInteger;\r\n\r\nfinal class GenerationLease {\r\n    private final LoadedGeneration loadedGeneration;\r\n    private final AtomicInteger references = new AtomicInteger(1);\r\n    private final AtomicBoolean retired = new AtomicBoolean(false);\r\n    private final AtomicBoolean closed = new AtomicBoolean(false);\r\n\r\n    GenerationLease(LoadedGeneration loadedGeneration) {\r\n        this.loadedGeneration = loadedGeneration;\r\n    }\r\n\r\n    GenerationLease retain() {\r\n        while (true) {\r\n            int current = references.get();\r\n            if (current == 0) {\r\n                throw new IllegalStateException(\"Generation \" + generation() + \" is already closed\");\r\n            }\r\n            if (references.compareAndSet(current, current + 1)) {\r\n                return this;\r\n            }\r\n        }\r\n    }\r\n\r\n    long generation() {\r\n        return loadedGeneration.generation();\r\n    }\r\n\r\n    PluginModule module() {\r\n        return loadedGeneration.module();\r\n    }\r\n\r\n    void retire() {\r\n        if (retired.compareAndSet(false, true)) {\r\n            release();\r\n        }\r\n    }\r\n\r\n    void release() {\r\n        int remaining = references.decrementAndGet();\r\n        if (remaining < 0) {\r\n            throw new IllegalStateException(\"Reference count underflow for generation \" + generation());\r\n        }\r\n        if (remaining == 0 && retired.get()) {\r\n            closeLoadedGeneration();\r\n        }\r\n    }\r\n\r\n    boolean isClosed() {\r\n        return closed.get();\r\n    }\r\n\r\n    private void closeLoadedGeneration() {\r\n        if (closed.compareAndSet(false, true)) {\r\n            try {\r\n                loadedGeneration.close();\r\n            } catch (Exception exception) {\r\n                throw new IllegalStateException(\"Unable to close generation \" + generation(), exception);\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
