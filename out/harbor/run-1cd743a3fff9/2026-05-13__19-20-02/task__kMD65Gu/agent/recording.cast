[227.605181, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nROOT_DIR=$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\r\n\r\nif [[ \"${TEXTD_SKIP_BUILD:-0}\" != \"1\" ]]; then\r\n  \"$ROOT_DIR/bin/build\"\r\nfi\r\n\r\njava -cp \"$ROOT_DIR/build/main-classes\" \\\r\n  io.harbor.textd.cli.HotReloadIntegrationRunner \\\r\n  \"$ROOT_DIR/build/plugins/customer-default.jar\" \\\r\n  \"${1:-12}\"\r\n"]
