[3.561953, "o", "\r\n./plugin-src/io:\r\n\u001b[01;34mharbor\u001b[0m\r\n\r\n./plugin-src/io/harbor:\r\n\u001b[01;34mtextd\u001b[0m\r\n\r\n./plugin-src/io/harbor/textd:\r\n\u001b[01;34mcustomer\u001b[0m\r\n\r\n./plugin-src/io/harbor/textd/customer:\r\nCustomerPluginFactory.java  CustomerPluginModule.java  PipelineProcessor.java  PipelineStages.java\r\n\r\n./src:\r\n\u001b[01;34mmain\u001b[0m\r\n\r\n./src/main:\r\n\u001b[01;34mjava\u001b[0m\r\n\r\n./src/main/java:\r\n\u001b[01;34mio\u001b[0m\r\n\r\n./src/main/java/io:\r\n\u001b[01;34mharbor\u001b[0m\r\n\r\n./src/main/java/io/harbor:\r\n\u001b[01;34mtextd\u001b[0m\r\n\r\n./src/main/java/io/harbor/textd:\r\n\u001b[01;34mapi\u001b[0m  \u001b[01;34mcli\u001b[0m  \u001b[01;34mcore\u001b[0m\r\n\r\n./src/main/java/io/harbor/textd/api:\r\nPluginModule.java  PluginModuleFactory.java  TextProcessor.java\r\n\r\n./src/main/java/io/harbor/textd/cli:\r\nHotReloadIntegrationRunner.java  HotReloadStressRunner.java  RuntimeDigestRunner.java  SessionReplayRunner.java\r\n\r\n./src/main/java/io/harbor/textd/core:\r\n"]
